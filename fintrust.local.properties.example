## Copy this file to: fintrust.local.properties
## Then fill your real credentials.

## SMTP (Gmail App Password)
FINTRUST_SMTP_HOST=smtp.gmail.com
FINTRUST_SMTP_PORT=587
FINTRUST_SMTP_STARTTLS=true
FINTRUST_SMTP_USERNAME=your_sender@gmail.com
FINTRUST_SMTP_PASSWORD=your_16_char_gmail_app_password
FINTRUST_SMTP_FROM=your_sender@gmail.com

## Twilio SMS
FINTRUST_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FINTRUST_TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FINTRUST_TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
