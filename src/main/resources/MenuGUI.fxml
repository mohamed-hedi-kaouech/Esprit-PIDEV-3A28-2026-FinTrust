<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="680.0" prefWidth="980.0" stylesheets="@Styles/MenuStyle.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.MenuGUIController">

    <VBox spacing="18" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" styleClass="main-container">
        <padding>
            <Insets top="20" right="24" bottom="20" left="24"/>
        </padding>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Menu Principal" styleClass="main-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userNameLabel" text="Utilisateur" styleClass="user-name"/>
            <Button text="Deconnexion" onAction="#handleLogout"/>
        </HBox>

        <HBox spacing="16">
            <VBox styleClass="menu-card" spacing="8" onMouseClicked="#goToProduct">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Produits" styleClass="card-title"/>
                <Label text="Gestion des produits" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToProduct" styleClass="card-button"/>
            </VBox>

            <VBox styleClass="menu-card" spacing="8" onMouseClicked="#goToBudget">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Budget" styleClass="card-title"/>
                <Label text="Gestion budget" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToBudget" styleClass="card-button"/>
            </VBox>

            <VBox styleClass="menu-card" spacing="8" onMouseClicked="#goToLoan">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Prets" styleClass="card-title"/>
                <Label text="Gestion prets" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToLoan" styleClass="card-button"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox styleClass="menu-card" spacing="8" onMouseClicked="#goToWallet">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Wallet" styleClass="card-title"/>
                <Label text="Gestion portefeuille" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToWallet" styleClass="card-button"/>
            </VBox>

            <VBox styleClass="menu-card" spacing="8" onMouseClicked="#goToPublication">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Publications" styleClass="card-title"/>
                <Label text="Gestion publications" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToPublication" styleClass="card-button"/>
            </VBox>

            <VBox fx:id="adminUserListCard" styleClass="menu-card" spacing="8" onMouseClicked="#goToAdminUsers">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Liste Utilisateurs" styleClass="card-title"/>
                <Label text="Validation et statuts" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToAdminUsers" styleClass="card-button"/>
            </VBox>

            <VBox fx:id="adminUserFormCard" styleClass="menu-card" spacing="8" onMouseClicked="#goToAdminUserForm">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Formulaire User" styleClass="card-title"/>
                <Label text="Creer ADMIN ou CLIENT" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToAdminUserForm" styleClass="card-button"/>
            </VBox>

            <VBox fx:id="adminKycCard" styleClass="menu-card" spacing="8" onMouseClicked="#goToAdminKycValidation">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Validation KYC" styleClass="card-title"/>
                <Label text="Approuver / Refuser KYC" styleClass="card-description"/>
                <Button text="Acceder" onAction="#goToAdminKycValidation" styleClass="card-button"/>
            </VBox>
        </HBox>
    </VBox>

</AnchorPane>
