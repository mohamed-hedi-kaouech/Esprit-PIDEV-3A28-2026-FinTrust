<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.ListPubController"
            prefWidth="1100" prefHeight="800"
            styleClass="app-root"
            stylesheets="@/Styles/BlueTheme.css">

    <VBox spacing="16.0" styleClass="page-shell"
          AnchorPane.topAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">

        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="topbar-card">
            <Button text="Retour"
                    onAction="#goBackToMenu"
                    prefWidth="110.0"
                    styleClass="btn-ghost"/>

            <Label text="Gestion Publications" styleClass="topbar-title">
                <font>
                    <Font name="System Bold" size="21.0"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Nouvelle Publication"
                    onAction="#goToCreatePage"
                    prefWidth="190.0"
                    styleClass="btn-primary"/>

            <Button text="Statistiques Feedback"
                    onAction="#goToFeedbackStats"
                    prefWidth="180.0"
                    styleClass="btn-outline"/>

            <Button text="Exporter stats mensuelles"
                    onAction="#exportMonthlyStats"
                    prefWidth="190.0"
                    styleClass="btn-outline"/>

        </HBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="search-row">
            <TextField fx:id="searchField"
                       promptText="Rechercher une publication..."
                       prefWidth="340.0"
                       styleClass="search-field"/>

            <Button text="Rechercher"
                    onAction="#handleSearch"
                    styleClass="btn-primary"/>

            <Button text="Reinitialiser"
                    onAction="#handleReset"
                    styleClass="btn-outline"/>
        </HBox>

        <ListView fx:id="publicationListView" VBox.vgrow="ALWAYS"/>

        <HBox alignment="CENTER">
            <Label fx:id="totalPublicationsLabel"
                   text="Total: 0 publications"
                   styleClass="muted-label"/>
        </HBox>
    </VBox>
</AnchorPane>
