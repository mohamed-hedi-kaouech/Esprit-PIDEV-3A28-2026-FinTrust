<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.FeedbackUserController"
            prefWidth="900.0"
            prefHeight="640.0"
            styleClass="app-root"
            stylesheets="@/Styles/BlueTheme.css">

    <VBox spacing="12.0" styleClass="page-shell"
          AnchorPane.topAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">

        <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="topbar-card">
            <Button text="Retour" fx:id="backButton" styleClass="btn-ghost"/>
            <Label fx:id="titleLabel" text="Feedbacks" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="8.0" alignment="CENTER_RIGHT">
                <Button fx:id="likeBtn" text="Like" styleClass="reaction-btn"/>
                <Label fx:id="likeCount" text="0" styleClass="topbar-count"/>
                <Button fx:id="dislikeBtn" text="Dislike" styleClass="reaction-btn"/>
                <Label fx:id="dislikeCount" text="0" styleClass="topbar-count"/>
            </HBox>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
            <VBox fx:id="feedbackList" styleClass="cards-stack"/>
        </ScrollPane>

        <VBox spacing="8.0" styleClass="composer-panel">
            <Label text="Rediger un feedback" styleClass="card-title"/>
            <TextArea fx:id="commentArea" prefRowCount="4" wrapText="true" styleClass="comment-input"/>
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Button fx:id="submitBtn" text="Envoyer" styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </VBox>
</AnchorPane>
