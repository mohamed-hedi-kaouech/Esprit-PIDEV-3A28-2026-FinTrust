<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.FeedbackUserController"
            prefWidth="800.0" prefHeight="600.0"
            stylesheets="@/Styles/BlueTheme.css">

    <VBox spacing="12.0" AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
        <HBox spacing="10" style="-fx-background-color: linear-gradient(to right, #1e90ff, #4facfe); -fx-padding: 14;" alignment="CENTER_LEFT">
            <Button text="⬅ Retour" fx:id="backButton" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight:bold;"/>
            <Label fx:id="titleLabel" text="Feedbacks" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button fx:id="likeBtn" text="👍" style="-fx-background-color: white; -fx-font-size:14px;" />
                <Label fx:id="likeCount" text="0" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button fx:id="dislikeBtn" text="👎" style="-fx-background-color: white; -fx-font-size:14px;" />
                <Label fx:id="dislikeCount" text="0" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox fx:id="feedbackList" spacing="10" padding="10"/>
        </ScrollPane>

        <VBox spacing="8" style="-fx-padding: 12; -fx-background-color: #f7fbff;">
            <Label text="Rédiger un feedback" style="-fx-font-weight: bold; -fx-text-fill: #0b5ed7;" />
            <TextArea fx:id="commentArea" prefRowCount="4" wrapText="true" />
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="submitBtn" text="Envoyer" style="-fx-background-color: #0b5ed7; -fx-text-fill: white; -fx-font-weight:bold;"/>
            </HBox>
        </VBox>
    </VBox>

</AnchorPane>
