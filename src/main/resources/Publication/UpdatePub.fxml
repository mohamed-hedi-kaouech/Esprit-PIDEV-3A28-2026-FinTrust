<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.EditPubController"
            prefHeight="700.0"
            prefWidth="980.0"
            styleClass="app-root"
            stylesheets="@/Styles/BlueTheme.css">

    <VBox spacing="14.0" styleClass="page-shell"
          AnchorPane.topAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">

        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="topbar-card">
            <Button text="Retour"
                    onAction="#goBackToList"
                    prefWidth="110.0"
                    styleClass="btn-ghost"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Modifier la Publication" styleClass="topbar-title">
                <font>
                    <Font name="System Bold" size="21.0"/>
                </font>
            </Label>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
            <VBox spacing="18.0" styleClass="form-container">
                <padding>
                    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                </padding>

                <TextField fx:id="publicationIdField"
                           visible="false"
                           managed="false"/>

                <VBox spacing="10.0" styleClass="info-card">
                    <Label text="Informations actuelles" styleClass="info-title"/>

                    <HBox spacing="30.0">
                        <VBox spacing="5.0">
                            <Label text="Titre actuel:" styleClass="form-label"/>
                            <Label fx:id="currentTitleLabel" text="-" styleClass="card-text"/>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Date actuelle:" styleClass="form-label"/>
                            <Label fx:id="currentDateLabel" text="-" styleClass="card-text"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Separator/>

                <VBox spacing="8.0">
                    <Label text="Nouveau Titre *" styleClass="form-label"/>
                    <TextField fx:id="titleField"
                               promptText="Entrez le nouveau titre..."
                               prefWidth="420.0"
                               styleClass="form-input"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Nouveau Contenu *" styleClass="form-label"/>

                    <TextArea fx:id="contentArea"
                              prefHeight="170.0"
                              wrapText="true"
                              promptText="Entrez le nouveau contenu..."
                              styleClass="form-textarea"/>

                    <Label fx:id="charCountLabel"
                           text="0 caractères"
                           styleClass="muted-label"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Date de création" styleClass="form-label"/>
                    <DatePicker fx:id="createdAtPicker"
                                disable="true"/>
                </VBox>

                <Separator/>

                <HBox alignment="CENTER" spacing="14.0">
                    <Button text="Modifier"
                            onAction="#handleUpdate"
                            prefWidth="160.0"
                            styleClass="btn-primary"/>

                    <Button text="Annuler"
                            onAction="#handleCancel"
                            prefWidth="160.0"
                            styleClass="btn-outline"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
