<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.EditPubController"
            stylesheets="@/Styles/StyleWallet.css"
            prefHeight="600.0"
            prefWidth="900.0">

    <!-- Header -->
    <VBox alignment="CENTER"
          prefHeight="80.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          styleClass="header">

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <padding>
                <Insets left="30.0" right="30.0"/>
            </padding>

            <Button text="⬅ Retour"
                    onAction="#goBackToList"
                    prefWidth="120.0" styleClass="btn-back"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Modifier la Publication" styleClass="header-title">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- Form Section -->
    <ScrollPane fitToWidth="true"
                AnchorPane.topAnchor="80.0"
                AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0">

        <VBox spacing="25.0">
            <padding>
                <Insets top="40.0" left="60.0" right="60.0" bottom="40.0"/>
            </padding>

            <!-- Hidden ID -->
            <TextField fx:id="publicationIdField"
                       visible="false"
                       managed="false"/>

            <!-- Current Info -->
            <VBox spacing="10.0">
                <Label text="📋 Informations actuelles">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>

                <HBox spacing="30.0">
                    <VBox spacing="5.0">
                        <Label text="Titre actuel:"/>
                        <Label fx:id="currentTitleLabel" text="-"/>
                    </VBox>

                    <VBox spacing="5.0">
                        <Label text="Date actuelle:"/>
                        <Label fx:id="currentDateLabel" text="-"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator/>

            <!-- Title -->
            <VBox spacing="8.0">
                <Label text="Nouveau Titre *">
                    <font>
                        <Font name="System Bold" size="13.0"/>
                    </font>
                </Label>
                <TextField fx:id="titleField"
                           promptText="Entrez le nouveau titre..."
                           prefWidth="400.0"/>
            </VBox>

            <!-- Content -->
            <VBox spacing="8.0">
                <Label text="Nouveau Contenu *">
                    <font>
                        <Font name="System Bold" size="13.0"/>
                    </font>
                </Label>

                <TextArea fx:id="contentArea"
                          prefHeight="150.0"
                          wrapText="true"
                          promptText="Entrez le nouveau contenu..."/>

                <Label fx:id="charCountLabel"
                       text="0 caractères"/>
            </VBox>

            <!-- Date (non modifiable) -->
            <VBox spacing="8.0">
                <Label text="Date de création"/>
                <DatePicker fx:id="createdAtPicker"
                            disable="true"/>
            </VBox>

            <Separator/>

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="20.0">

                <Button text="Modifier"
                        onAction="#handleUpdate"
                        prefWidth="160.0"/>

                <Button text="Annuler"
                        onAction="#handleCancel"
                        prefWidth="160.0"/>

            </HBox>

        </VBox>
    </ScrollPane>

</AnchorPane>
