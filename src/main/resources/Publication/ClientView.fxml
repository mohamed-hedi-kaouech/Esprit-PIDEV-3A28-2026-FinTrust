<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.ClientController"
            prefWidth="900.0"
            prefHeight="640.0">

    <VBox spacing="10.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">
        <HBox spacing="10.0"
              style="-fx-background-color: linear-gradient(to right, #1e90ff, #4facfe); -fx-padding: 14;"
              alignment="CENTER_LEFT">
            <Button fx:id="backBtn"
                    text="Retour"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label text="Espace Client - Publications"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="8.0" style="-fx-padding: 10 20 0 20;">
            <TextField fx:id="searchField" promptText="Rechercher..." HBox.hgrow="ALWAYS"/>
            <Button text="Rechercher" onAction="#handleSearch"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox fx:id="clientListContainer" spacing="12.0" style="-fx-padding: 20;"/>
        </ScrollPane>
    </VBox>
</AnchorPane>
