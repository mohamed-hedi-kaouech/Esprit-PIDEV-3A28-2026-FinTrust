<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.FeedbackController"
            prefHeight="600.0"
            prefWidth="900.0"
            stylesheets="@/Styles/StyleWallet.css">

    <VBox alignment="TOP_CENTER" AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="header" prefHeight="80.0" prefWidth="900.0">
            <padding>
                <Insets left="20" right="20"/>
            </padding>
            <Button text="⬅ Retour" onAction="#goBack" styleClass="btn-back" prefWidth="120.0"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Feedbacks - Publications" styleClass="header-title">
                <font>
                    <Font name="System Bold" size="22"/>
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <ScrollPane fitToWidth="true" prefHeight="520.0">
            <VBox fx:id="listContainer" spacing="12">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
            </VBox>
        </ScrollPane>
    </VBox>

</AnchorPane>
