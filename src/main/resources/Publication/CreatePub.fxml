<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.CreationPubController"
            stylesheets="@/Styles/StyleWallet.css"
            prefHeight="600.0"
            prefWidth="900.0">

    <!-- Header -->
    <VBox alignment="CENTER" prefHeight="80.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          styleClass="header">

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <padding>
                <Insets left="30.0" right="30.0"/>
            </padding>

            <Button onAction="#goBackToList"
                    prefWidth="120.0"
                    styleClass="btn-back"
                    text="⬅ Retour"/>

            <Button onAction="#checkDbConnection"
                    prefWidth="140.0"
                    styleClass="btn-secondary"
                    text="Statut DB"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Créer une Nouvelle Publication"
                   styleClass="header-title">
                <font>
                    <Font name="System Bold" size="22"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- Form -->
    <ScrollPane fitToWidth="true"
                AnchorPane.topAnchor="80.0"
                AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0">

        <VBox spacing="25.0" styleClass="form-container">
            <padding>
                <Insets top="40" left="60" right="60" bottom="40"/>
            </padding>

            <!-- Titre -->
            <VBox spacing="8">
                <Label text="Titre *" styleClass="form-label"/>
                <TextField fx:id="titreField"
                           promptText="Entrez le titre..."
                           styleClass="form-input"/>
            </VBox>

            <!-- Catégorie -->
            <VBox spacing="8">
                <Label text="Catégorie *" styleClass="form-label"/>
                <TextField fx:id="categorieField"
                           promptText="Ex: Finance, Crédit, Investissement"
                           styleClass="form-input"/>
            </VBox>

            <!-- Statut -->
            <VBox spacing="8">
                <Label text="Statut" styleClass="form-label"/>
                <TextField fx:id="statutField"
                           promptText="Ex: Brouillon / Publié"
                           styleClass="form-input"/>
            </VBox>

            <!-- Date -->
            <VBox spacing="8">
                <Label text="Date de publication" styleClass="form-label"/>
                <DatePicker fx:id="datePicker" styleClass="form-input"/>
            </VBox>

            <!-- Visibilité -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <CheckBox fx:id="estVisibleCheck" text="Publication visible"/>
            </HBox>

            <!-- Contenu -->
            <VBox spacing="8">
                <Label text="Contenu *" styleClass="form-label"/>
                <TextArea fx:id="contenuArea"
                          prefHeight="150"
                          wrapText="true"
                          promptText="Entrez le contenu de la publication..."
                          styleClass="form-textarea"/>

                <HBox>
                    <Label fx:id="charCountLabel"
                           text="0/500 caractères"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="* Champs obligatoires"/>
                </HBox>
            </VBox>

            <Separator/>

            <!-- Boutons -->
            <HBox alignment="CENTER" spacing="20">
                <Button text="Enregistrer"
                        onAction="#createPublication"
                        styleClass="btn-primary"/>

                <Button text="Réinitialiser"
                        onAction="#handleClear"
                        styleClass="btn-secondary"/>
            </HBox>

        </VBox>
    </ScrollPane>
</AnchorPane>
