<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.PublicationControlleur.CreationPubController"
            prefWidth="1100" prefHeight="800"
            styleClass="app-root"
            stylesheets="@/Styles/BlueTheme.css">

    <VBox spacing="14.0" styleClass="page-shell"
          AnchorPane.topAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0">

        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="topbar-card">
            <Button onAction="#goBackToList"
                    prefWidth="110.0"
                    styleClass="btn-ghost"
                    text="Retour"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Créer une Nouvelle Publication" styleClass="topbar-title">
                <font>
                    <Font name="System Bold" size="21.0"/>
                </font>
            </Label>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
            <VBox spacing="18.0" styleClass="form-container">
                <padding>
                    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                </padding>

                <VBox spacing="8.0">
                    <Label text="Titre *" styleClass="form-label"/>
                    <TextField fx:id="titreField"
                               promptText="Entrez le titre..."
                               styleClass="form-input"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Catégorie *" styleClass="form-label"/>
                    <ComboBox fx:id="categorieField"
                              promptText="Choisir une catégorie"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Statut" styleClass="form-label"/>
                    <ComboBox fx:id="statutField"
                              promptText="Choisir un statut"/>
                </VBox>

                <VBox spacing="8.0">
                    <Label text="Date de publication" styleClass="form-label"/>
                    <DatePicker fx:id="datePicker"/>
                </VBox>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <CheckBox fx:id="estVisibleCheck" text="Publication visible"/>
                </HBox>

                <VBox spacing="8.0">
                    <Label text="Contenu *" styleClass="form-label"/>
                    <TextArea fx:id="contenuArea"
                              prefHeight="170.0"
                              wrapText="true"
                              promptText="Entrez le contenu de la publication..."
                              styleClass="form-textarea"/>

                    <HBox>
                        <Label fx:id="charCountLabel"
                               text="0/500 caractères"
                               styleClass="muted-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="* Champs obligatoires" styleClass="muted-label"/>
                    </HBox>
                </VBox>

                <Separator/>

                <HBox alignment="CENTER" spacing="14.0">
                    <Button text="Enregistrer"
                            onAction="#createPublication"
                            styleClass="btn-primary"/>

                    <Button text="Réinitialiser"
                            onAction="#handleClear"
                            styleClass="btn-outline"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
