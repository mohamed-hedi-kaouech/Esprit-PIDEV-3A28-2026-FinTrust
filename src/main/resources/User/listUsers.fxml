<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" stylesheets="/Styles/StyleUser.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.UserControlleur.ListUsersController">

    <!-- Main Container -->
    <VBox spacing="20.0" AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
        <padding>
            <Insets top="30.0" left="30.0" right="30.0" bottom="30.0" />
        </padding>

        <!-- Header Section -->
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-container">
            <Button onAction="#goBackToMenu" prefWidth="120.0" styleClass="btn-back" text="⬅ Retour">
                <font>
                    <Font name="System Bold" size="13.0"/>
                </font>
            </Button>

            <Label styleClass="page-title" text="Liste des Utilisateurs">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Button styleClass="btn-add" text="➕ Nouvel Utilisateur" onAction="#goToCreateUserPage" prefWidth="180.0">
                <font>
                    <Font name="System Bold" size="13.0"/>
                </font>
            </Button>
        </HBox>

        <!-- List Section -->
        <VBox spacing="15.0" styleClass="list-container" VBox.vgrow="ALWAYS">

            <!-- Search Bar -->
            <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="search-container">
                <TextField fx:id="searchField" promptText="🔍 Rechercher un utilisateur..." prefWidth="300.0" styleClass="search-input"/>
                <Button text="Rechercher" styleClass="btn-search" onAction="#handleSearch"/>
                <Button text="Réinitialiser" styleClass="btn-reset" onAction="#handleReset"/>
            </HBox>

            <!-- ListView with Custom Cells -->
            <ListView fx:id="userListView" styleClass="user-listview" VBox.vgrow="ALWAYS">
                <!-- Ici, tu peux utiliser un CellFactory pour afficher nom, prénom, email, rôle, statut KYC -->
            </ListView>

            <!-- Pagination Info -->
            <HBox alignment="CENTER" spacing="10.0" styleClass="pagination-info">
                <Label fx:id="totalUsersLabel" text="Total: 0 utilisateurs" styleClass="info-label">
                    <font>
                        <Font size="12.0"/>
                    </font>
                </Label>
            </HBox>
        </VBox>
    </VBox>

</AnchorPane>
