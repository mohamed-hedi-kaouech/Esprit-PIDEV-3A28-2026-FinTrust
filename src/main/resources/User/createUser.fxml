<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" stylesheets="/Styles/StyleProduct.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.UserControlleur.UserCreationController">

    <!-- Header Section -->
    <VBox alignment="CENTER" prefHeight="80.0" prefWidth="900.0" styleClass="header"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
            <Button onAction="#goBackToList" prefWidth="120.0" styleClass="btn-back" text="⬅ Retour">
                <font>
                    <Font name="System Bold" size="13.0" />
                </font>
            </Button>
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="header-title" text="Créer un Nouvel Utilisateur">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>

    <!-- Main Form -->
    <ScrollPane fitToWidth="true" layoutY="80.0" prefHeight="520.0" prefWidth="900.0"
                styleClass="form-scroll"
                AnchorPane.topAnchor="80.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <VBox spacing="20.0" styleClass="form-container">
            <padding>
                <Insets top="40" bottom="40" left="60" right="60"/>
            </padding>

            <!-- Form Title -->
            <VBox spacing="8.0" styleClass="form-intro">
                <Label styleClass="form-section-title" text="Informations Utilisateur">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>
                <Separator prefWidth="200"/>
                <Label styleClass="form-subtitle" text="Remplissez les champs ci-dessous pour créer un utilisateur"/>
            </VBox>

            <!-- Nom -->
            <VBox spacing="8.0" styleClass="input-group">
                <Label styleClass="form-label" text="Nom *"/>
                <TextField fx:id="txtNom" promptText="Nom" styleClass="form-input" prefWidth="400"/>
            </VBox>

            <!-- Prénom -->
            <VBox spacing="8.0" styleClass="input-group">
                <Label styleClass="form-label" text="Prénom *"/>
                <TextField fx:id="txtPrenom" promptText="Prénom" styleClass="form-input" prefWidth="400"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="8.0" styleClass="input-group">
                <Label styleClass="form-label" text="Email *"/>
                <TextField fx:id="txtEmail" promptText="exemple@domaine.com" styleClass="form-input" prefWidth="400"/>
            </VBox>

            <!-- Numéro de téléphone -->
            <VBox spacing="8.0" styleClass="input-group">
                <Label styleClass="form-label" text="Numéro de téléphone *"/>
                <TextField fx:id="txtNumTel" promptText="Ex: 12345678" styleClass="form-input" prefWidth="400"/>
            </VBox>

            <!-- Mot de passe -->
            <VBox spacing="8.0" styleClass="input-group">
                <Label styleClass="form-label" text="Mot de passe *"/>
                <PasswordField fx:id="txtPassword" promptText="Mot de passe" styleClass="form-input" prefWidth="400"/>
            </VBox>

            <!-- Rôle -->
            <VBox spacing="8.0" styleClass="input-group">
                <Label styleClass="form-label" text="Rôle *"/>
                <ComboBox fx:id="comboRole" prefWidth="400" styleClass="form-input">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="USER"/>
                            <String fx:value="ADMIN"/>
                            <String fx:value="GUEST"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <!-- Statut -->
            <VBox spacing="8.0" styleClass="input-group">
                <Label styleClass="form-label" text="Statut *"/>
                <ComboBox fx:id="statusComboBox" prefWidth="400.0" promptText="Sélectionner un statut" styleClass="form-input">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="EN ATTENTE" />
                            <String fx:value="VALIDÉ" />
                            <String fx:value="INACTIF" />
                        </FXCollections>
                    </items>
                </ComboBox>

            </VBox>

            <Separator prefWidth="200"/>

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="20.0" styleClass="button-container">
                <Button fx:id="saveButton" onAction="#createUser" prefWidth="180" styleClass="btn-primary" text="Enregistrer"/>
                <Button fx:id="clearButton" onAction="#handleClear" prefWidth="180" styleClass="btn-secondary" text="Réinitialiser"/>
            </HBox>

            <!-- Info Box -->
            <VBox spacing="10.0" styleClass="info-box">
                <Label styleClass="info-title" text="Informations importantes"/>
                <Label styleClass="info-text" text="• Tous les champs marqués d'un * sont obligatoires." wrapText="true"/>
                <Label styleClass="info-text" text="• Assurez-vous que l'email est valide." wrapText="true"/>
            </VBox>

        </VBox>
    </ScrollPane>

</AnchorPane>
