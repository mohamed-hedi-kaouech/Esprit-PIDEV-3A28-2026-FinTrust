<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="680.0"
        prefWidth="960.0"
        style="-fx-background-color: #f4f6f9;"
        stylesheets="/Styles/StyleProduct.css"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.Controlleurs.ProductControlleur.Client.ClientListeProductControlleur">

    <VBox
            spacing="0"
            AnchorPane.topAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0"
            AnchorPane.bottomAnchor="0.0">

        <!-- ══════════════════════════════════════════════ -->
        <!--  TOP HEADER BAR                               -->
        <!-- ══════════════════════════════════════════════ -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="16.0"
                style="-fx-background-color: white;
                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0, 0, 2);">
            <padding>
                <Insets top="20.0" left="30.0" right="30.0" bottom="20.0"/>
            </padding>

            <!-- Icon + Title -->
            <Label
                    text="📦"
                    style="-fx-font-size: 26px;"/>
            <VBox spacing="2.0">
                <Label
                        text="Mes Abonnements"
                        style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a237e;">
                    <font><Font name="System Bold" size="20.0"/></font>
                </Label>
                <Label
                        text="Gérez vos produits et abonnements actifs"
                        style="-fx-font-size: 12px; -fx-text-fill: #78909c;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Total badge -->
            <HBox
                    alignment="CENTER"
                    spacing="6.0"
                    style="-fx-background-color: #e8eaf6;
                       -fx-background-radius: 20px;
                       -fx-padding: 6px 16px;">
                <Label
                        text="Total :"
                        style="-fx-font-size: 12px; -fx-text-fill: #3949ab;"/>
                <Label
                        fx:id="totalProductsLabel"
                        text="0 abonnement"
                        style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1a237e;">
                    <font><Font name="System Bold" size="12.0"/></font>
                </Label>
            </HBox>
        </HBox>

        <!-- ══════════════════════════════════════════════ -->
        <!--  SEARCH / FILTER BAR                          -->
        <!-- ══════════════════════════════════════════════ -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="10.0"
                style="-fx-background-color: #ffffff;
                   -fx-border-color: #e0e0e0;
                   -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="14.0" left="30.0" right="30.0" bottom="14.0"/>
            </padding>

            <!-- Search icon label -->
            <Label
                    text="🔍"
                    style="-fx-font-size: 14px;"/>

            <TextField
                    fx:id="searchField"
                    promptText="Rechercher par catégorie, type, statut, description..."
                    prefWidth="380.0"
                    style="-fx-background-radius: 8px;
                       -fx-border-color: #e0e0e0;
                       -fx-border-radius: 8px;
                       -fx-padding: 8px 12px;
                       -fx-font-size: 13px;
                       -fx-text-fill: #37474f;"/>

            <Button
                    text="Rechercher"
                    onAction="#handleSearch"
                    style="-fx-background-color: #3949ab;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 12px;
                       -fx-background-radius: 8px;
                       -fx-padding: 8px 20px;
                       -fx-cursor: hand;"/>

            <Button
                    text="↺  Réinitialiser"
                    onAction="#handleReset"
                    style="-fx-background-color: #eceff1;
                       -fx-text-fill: #546e7a;
                       -fx-font-size: 12px;
                       -fx-background-radius: 8px;
                       -fx-padding: 8px 16px;
                       -fx-cursor: hand;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Filter hint -->
            <Label
                    text="Filtrez par catégorie, statut ou type d'abonnement"
                    style="-fx-font-size: 11px; -fx-text-fill: #b0bec5; -fx-font-style: italic;"/>
        </HBox>

        <!-- ══════════════════════════════════════════════ -->
        <!--  MAIN LIST                                     -->
        <!-- ══════════════════════════════════════════════ -->
        <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: #f4f6f9;">
            <padding>
                <Insets top="16.0" left="20.0" right="20.0" bottom="16.0"/>
            </padding>

            <ListView
                    fx:id="SubProductsListeView"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;
                       -fx-border-color: transparent;
                       -fx-padding: 0;"/>
        </VBox>

    </VBox>

</AnchorPane>
