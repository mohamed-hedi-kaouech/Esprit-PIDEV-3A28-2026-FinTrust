<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="720.0"
        prefWidth="1100.0"
        style="-fx-background-color: #0f1923;"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.Controlleurs.ProductControlleur.MenuProductControlleur">

    <VBox
            spacing="0"
            AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
            AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ══ TOP NAV BAR ══ -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="12"
                style="-fx-background-color: #111d2b;
                   -fx-border-color: #1e3a5f;
                   -fx-border-width: 0 0 1 0;">
            <Button text="⬅ Retour" onAction="#goBackToMenu" styleClass="btn-back">
                <font>
                    <Font name="System Bold" size="13.0" />
                </font>
            </Button>
            <padding><Insets top="18" left="32" right="32" bottom="18"/></padding>

            <Label text="⬡"
                   style="-fx-text-fill: #3b9eff; -fx-font-size: 22px;"/>
            <Label text="FinTrustBank"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="· Product Suite"
                   style="-fx-text-fill: #4a7fa5; -fx-font-size: 14px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Portail Produits"
                   style="-fx-text-fill: #4a7fa5; -fx-font-size: 11px; -fx-font-style: italic;"/>


        </HBox>

        <!-- ══ HERO SECTION ══ -->
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #0f1923;">
            <padding><Insets top="60" bottom="50"/></padding>

            <Label text="Gestion des Produits"
                   style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
            <Label text="Sélectionnez une section pour commencer"
                   style="-fx-text-fill: #4a7fa5; -fx-font-size: 14px;"/>
        </VBox>

        <!-- ══ NAVIGATION CARDS ══ -->
        <HBox alignment="CENTER" spacing="24" VBox.vgrow="ALWAYS">
            <padding><Insets left="40" right="40" bottom="60"/></padding>

            <!-- Market Card -->
            <VBox
                    fx:id="marketCard"
                    alignment="CENTER"
                    spacing="16"
                    prefWidth="220"
                    prefHeight="260"
                    onMouseClicked="#navigateToMarket"
                    style="-fx-background-color: #111d2b;
                       -fx-background-radius: 16px;
                       -fx-border-color: #1e3a5f;
                       -fx-border-radius: 16px;
                       -fx-border-width: 1;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 16, 0, 0, 4);">
                <padding><Insets top="36" bottom="36" left="24" right="24"/></padding>

                <Label text="🛒"
                       style="-fx-font-size: 48px;"/>
                <Label text="Marché"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Parcourez et souscrivez\naux produits disponibles"
                       wrapText="true"
                       style="-fx-text-fill: #4a7fa5; -fx-font-size: 12px; -fx-text-alignment: center;"
                       alignment="CENTER"/>
                <Label text="CLIENT"
                       style="-fx-background-color: #0d3b66;
                           -fx-text-fill: #3b9eff;
                           -fx-font-size: 10px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20px;
                           -fx-padding: 4px 14px;"/>
            </VBox>

            <!-- My Subscriptions Card -->
            <VBox
                    fx:id="mySubsCard"
                    alignment="CENTER"
                    spacing="16"
                    prefWidth="220"
                    prefHeight="260"
                    onMouseClicked="#navigateToClientList"
                    style="-fx-background-color: #111d2b;
                       -fx-background-radius: 16px;
                       -fx-border-color: #1e3a5f;
                       -fx-border-radius: 16px;
                       -fx-border-width: 1;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 16, 0, 0, 4);">
                <padding><Insets top="36" bottom="36" left="24" right="24"/></padding>

                <Label text="📋"
                       style="-fx-font-size: 48px;"/>
                <Label text="Mes Abonnements"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Consultez et gérez\nvos abonnements actifs"
                       wrapText="true"
                       style="-fx-text-fill: #4a7fa5; -fx-font-size: 12px; -fx-text-alignment: center;"
                       alignment="CENTER"/>
                <Label text="CLIENT"
                       style="-fx-background-color: #0d3b66;
                           -fx-text-fill: #3b9eff;
                           -fx-font-size: 10px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20px;
                           -fx-padding: 4px 14px;"/>
            </VBox>

            <!-- Admin Products Card -->
            <VBox
                    fx:id="adminCard"
                    alignment="CENTER"
                    spacing="16"
                    prefWidth="220"
                    prefHeight="260"
                    onMouseClicked="#navigateToAdminList"
                    style="-fx-background-color: #111d2b;
                       -fx-background-radius: 16px;
                       -fx-border-color: #1e3a5f;
                       -fx-border-radius: 16px;
                       -fx-border-width: 1;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 16, 0, 0, 4);">
                <padding><Insets top="36" bottom="36" left="24" right="24"/></padding>

                <Label text="⚙️"
                       style="-fx-font-size: 48px;"/>
                <Label text="Produits Admin"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Gérez le catalogue\nde produits bancaires"
                       wrapText="true"
                       style="-fx-text-fill: #4a7fa5; -fx-font-size: 12px; -fx-text-alignment: center;"
                       alignment="CENTER"/>
                <Label text="ADMIN"
                       style="-fx-background-color: #2d1b00;
                           -fx-text-fill: #f5a623;
                           -fx-font-size: 10px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20px;
                           -fx-padding: 4px 14px;"/>
            </VBox>
            <!-- Admin adminSub Products -->
            <VBox
                    fx:id="adminSub"
                    alignment="CENTER"
                    spacing="16"
                    prefWidth="220"
                    prefHeight="260"
                    onMouseClicked="#navigateToAdminListSub"
                    style="-fx-background-color: #111d2b;
                       -fx-background-radius: 16px;
                       -fx-border-color: #1e3a5f;
                       -fx-border-radius: 16px;
                       -fx-border-width: 1;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 16, 0, 0, 4);">
                <padding><Insets top="36" bottom="36" left="24" right="24"/></padding>

                <Label text="🔔"
                       style="-fx-font-size: 48px;"/>
                <Label text="Sub Produits Admin"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Gérez les Abonners des clients bancaires"
                       wrapText="true"
                       style="-fx-text-fill: #4a7fa5; -fx-font-size: 12px; -fx-text-alignment: center;"
                       alignment="CENTER"/>
                <Label text="ADMIN"
                       style="-fx-background-color: #2d1b00;
                           -fx-text-fill: #f5a623;
                           -fx-font-size: 10px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20px;
                           -fx-padding: 4px 14px;"/>
            </VBox>
            <!-- Dashboard Card -->
            <VBox
                    fx:id="dashboardCard"
                    alignment="CENTER"
                    spacing="16"
                    prefWidth="220"
                    prefHeight="260"
                    onMouseClicked="#navigateToDashboard"
                    style="-fx-background-color: #0d2137;
                       -fx-background-radius: 16px;
                       -fx-border-color: #1e5a9e;
                       -fx-border-radius: 16px;
                       -fx-border-width: 2;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(59,158,255,0.15), 20, 0, 0, 0);">
                <padding><Insets top="36" bottom="36" left="24" right="24"/></padding>

                <Label text="📊"
                       style="-fx-font-size: 48px;"/>
                <Label text="Dashboard"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="KPIs, statistiques\net graphiques analytiques"
                       wrapText="true"
                       style="-fx-text-fill: #4a7fa5; -fx-font-size: 12px; -fx-text-alignment: center;"
                       alignment="CENTER"/>
                <Label text="ADMIN · ANALYTICS"
                       style="-fx-background-color: #0d3b66;
                           -fx-text-fill: #3b9eff;
                           -fx-font-size: 10px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20px;
                           -fx-padding: 4px 14px;"/>
            </VBox>

        </HBox>

        <!-- ══ STATUS BAR ══ -->
        <HBox
                alignment="CENTER_LEFT"
                spacing="20"
                style="-fx-background-color: #080f17;
                   -fx-border-color: #1e3a5f;
                   -fx-border-width: 1 0 0 0;">
            <padding><Insets top="12" bottom="12" left="32" right="32"/></padding>

            <Label text="● Système opérationnel"
                   style="-fx-text-fill: #2ecc71; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="BankOS Product Suite v2.0"
                   style="-fx-text-fill: #2a4a6b; -fx-font-size: 11px;"/>
        </HBox>

    </VBox>
</AnchorPane>
