<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            fx:controller="org.example.Controlleurs.AuthControlleur.AuthLoginController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT">
            <children>
                <Label text="FinTrust - Connexion" styleClass="logo-text"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="admin-dashboard-scroll">
            <content>
        <VBox spacing="18" alignment="CENTER" style="-fx-padding: 40 24;" styleClass="bank-card" maxWidth="520">
            <HBox alignment="CENTER" styleClass="section-header">
                <Label text="Se connecter" styleClass="section-title" />
            </HBox>
            <Label text="Connectez-vous pour accéder à votre espace" styleClass="section-subtitle" />
            <Label text="Email" styleClass="form-label" />
            <TextField fx:id="emailField" promptText="Email" maxWidth="360" style="-fx-background-color: #e2edff; -fx-border-color: #1e3a8a; -fx-border-radius: 8; -fx-background-radius: 8;" />
            <Label text="Mot de passe" styleClass="form-label" />
            <PasswordField fx:id="passwordField" promptText="Mot de passe" maxWidth="360" style="-fx-background-color: #e2edff; -fx-border-color: #1e3a8a; -fx-border-radius: 8; -fx-background-radius: 8;" />
            <HBox alignment="CENTER" style="-fx-padding: 18 0 0 0;">
                 <Button text="Se connecter" onAction="#handleLogin" styleClass="new-transaction-button" maxWidth="220" />
            </HBox>
            <Label fx:id="messageLabel" text="" styleClass="section-subtitle" maxWidth="420" wrapText="true" />
            <Hyperlink text="Créer un compte" onAction="#goToSignup" style="-fx-text-fill: #1e3a8a; -fx-font-weight: 700;" />
              <Hyperlink text="Mot de passe oublié ?" onAction="#goToPasswordReset" style="-fx-text-fill: #2563eb; -fx-font-weight: 700;" />
        </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
