<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.AuthControlleur.AuthSignupController"
            prefHeight="560" prefWidth="860"
            style="-fx-background-color: linear-gradient(to bottom right, #f3f8ff, #e9f3ff);">

    <center>
        <HBox alignment="CENTER" spacing="0">
            <VBox alignment="CENTER" spacing="20"
                  prefWidth="350" prefHeight="560"
                  style="-fx-background-color: linear-gradient(to bottom, #2a68c8, #3f8efc); -fx-padding: 50;">

                <Label text="FinTrust"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Label text="La Confiance Par La Finance "
                       style="-fx-font-size: 14px; -fx-text-fill: #d9e8ff;"/>

                <VBox alignment="CENTER" spacing="15" style="-fx-padding: 30 0 0 0;">
                    <Label text="&#128272;" style="-fx-font-size: 40px;"/>
                    <Label text="Inscription securisée"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Creation rapide de votre espace client"
                           style="-fx-font-size: 12px; -fx-text-fill: #d9e8ff;"/>
                </VBox>
            </VBox>

            <VBox alignment="CENTER" spacing="14"
                  prefWidth="510" prefHeight="560"
                  style="-fx-background-color: white; -fx-padding: 34; -fx-background-radius: 0 18 18 0;">

                <Label text="Creer un compte"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>

                <Label text="Votre compte sera en attente de validation admin"
                       style="-fx-font-size: 14px; -fx-text-fill: #6B7280;"/>

                <VBox spacing="10" maxWidth="350">
                    <Label text="Nom" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <TextField fx:id="nomField" promptText="Nom complet"
                               style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Label text="Prenom" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <TextField fx:id="prenomField" promptText="Prenom"
                               style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <TextField fx:id="emailField" promptText="votre@email.com"
                               style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Label text="Telephone" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <TextField fx:id="numTelField" promptText="Numero de telephone"
                               style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <PasswordField fx:id="passwordField" promptText="Mot de passe"
                                   style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Label text="Confirmation mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"
                                   style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>
                </VBox>

                <Button text="Creer le compte"
                        onAction="#handleSignup"
                        maxWidth="280"
                        style="-fx-background-color: linear-gradient(to right, #2a68c8, #3f8efc); -fx-text-fill: white; -fx-padding: 11; -fx-background-radius: 30; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="360"
                       style="-fx-font-size: 13px; -fx-text-fill: #cc2e2e;"/>

                <HBox spacing="8" alignment="CENTER">
                    <Label text="Deja un compte ?" style="-fx-text-fill: #6B7280;"/>
                    <Hyperlink text="Retour a la connexion" onAction="#goToLogin"
                               style="-fx-text-fill: #2a68c8; -fx-font-weight: bold;"/>
                </HBox>

                <padding>
                    <Insets top="6"/>
                </padding>
            </VBox>
        </HBox>
    </center>
</BorderPane>
