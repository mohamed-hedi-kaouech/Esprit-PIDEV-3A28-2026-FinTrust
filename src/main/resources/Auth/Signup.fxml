<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            fx:controller="org.example.Controlleurs.AuthControlleur.AuthSignupController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT">
            <children>
                <Label text="FinTrust - Inscription" styleClass="logo-text"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 26 20;" styleClass="bank-card" maxWidth="560">
            <HBox styleClass="section-header">
                <Label text="Creer un compte" styleClass="section-title"/>
            </HBox>
            <Label text="Votre compte sera en attente de validation admin" styleClass="section-subtitle"/>

            <Label text="Nom" styleClass="form-label"/>
            <TextField fx:id="nomField" promptText="Nom complet" maxWidth="380"/>
            <Label text="Prenom" styleClass="form-label"/>
            <TextField fx:id="prenomField" promptText="Prenom" maxWidth="380"/>
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="emailField" promptText="Email" maxWidth="380"/>
            <Label text="Telephone" styleClass="form-label"/>
            <TextField fx:id="numTelField" promptText="Numero de telephone" maxWidth="380"/>
            <Label text="Mot de passe" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" promptText="Mot de passe" maxWidth="380"/>
            <Label text="Confirmation mot de passe" styleClass="form-label"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe" maxWidth="380"/>

            <Button text="Creer le compte" onAction="#handleSignup" styleClass="button-primary" maxWidth="240"/>
            <Label fx:id="messageLabel" text="" styleClass="section-subtitle" maxWidth="420" wrapText="true"/>
            <Hyperlink text="Retour a la connexion" onAction="#goToLogin"/>
        </VBox>
    </center>
</BorderPane>
