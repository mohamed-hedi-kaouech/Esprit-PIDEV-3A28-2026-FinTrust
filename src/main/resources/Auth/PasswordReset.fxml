<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.AuthControlleur.PasswordResetController"
            prefHeight="560" prefWidth="860"
            style="-fx-background-color: linear-gradient(to bottom right, #f3f8ff, #e9f3ff);">

    <center>
        <HBox alignment="CENTER" spacing="0">
            <VBox alignment="CENTER" spacing="20"
                  prefWidth="350" prefHeight="560"
                  style="-fx-background-color: linear-gradient(to bottom, #2a68c8, #3f8efc); -fx-padding: 50;">

                <Label text="FinTrust"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Label text="La confiance par la finance"
                       style="-fx-font-size: 14px; -fx-text-fill: #d9e8ff;"/>

                <VBox alignment="CENTER" spacing="15" style="-fx-padding: 30 0 0 0;">
                    <Label text="&#128273;" style="-fx-font-size: 40px;"/>
                    <Label text="Recuperation securisee"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Reinitialisez votre mot de passe en quelques etapes"
                           style="-fx-font-size: 12px; -fx-text-fill: #d9e8ff;"/>
                </VBox>
            </VBox>

            <VBox alignment="CENTER" spacing="12"
                  prefWidth="510" prefHeight="560"
                  style="-fx-background-color: white; -fx-padding: 34; -fx-background-radius: 0 18 18 0;">

                <Label text="Mot de passe oublie"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>

                <Label text="Entrez votre email pour recevoir un code"
                       style="-fx-font-size: 14px; -fx-text-fill: #6B7280;"/>

                <VBox spacing="10" maxWidth="350">
                    <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <TextField fx:id="emailField" promptText="votre@email.com"
                               style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Button text="Envoyer le code" onAction="#handleSendCode"
                            style="-fx-background-color: linear-gradient(to right, #2a68c8, #3f8efc); -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 24; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                    <Label fx:id="codeLabel" text="Code non envoye" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <TextField fx:id="codeField" promptText="Code"
                               style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Label text="Nouveau mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <PasswordField fx:id="newPasswordField" promptText="Nouveau mot de passe"
                                   style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>

                    <Label text="Confirmation mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #1e4f97;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"
                                   style="-fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #d8e6ff; -fx-border-radius: 10;"/>
                </VBox>

                <Button text="Valider"
                        onAction="#handleResetPassword"
                        maxWidth="280"
                        style="-fx-background-color: linear-gradient(to right, #2a68c8, #3f8efc); -fx-text-fill: white; -fx-padding: 11; -fx-background-radius: 30; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>

                <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="360"
                       style="-fx-font-size: 13px; -fx-text-fill: #cc2e2e;"/>

                <Button text="Retour a la connexion"
                        onAction="#goToLogin"
                        maxWidth="220"
                        style="-fx-background-color: white; -fx-text-fill: #2a68c8; -fx-border-color: #2a68c8; -fx-border-radius: 24; -fx-background-radius: 24; -fx-padding: 10; -fx-font-weight: bold;"/>

                <padding>
                    <Insets top="6"/>
                </padding>
            </VBox>
        </HBox>
    </center>
</BorderPane>