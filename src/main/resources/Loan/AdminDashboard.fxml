<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<AnchorPane prefWidth="1200" prefHeight="750"
            stylesheets="@/Styles/LoanStyle.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controlleurs.LoanControlleur.AdminDashboardController"
            styleClass="root">

    <VBox spacing="40"
          AnchorPane.topAnchor="40"
          AnchorPane.leftAnchor="60"
          AnchorPane.rightAnchor="60"
          AnchorPane.bottomAnchor="40">

        <!-- ================= TITLE ================= -->
        <HBox alignment="CENTER_LEFT">
            <Label text="Admin Dashboard"
                   styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="back"
                    styleClass="btn-back"
                    onAction="#handleback"/>
        </HBox>

        <!-- ================= STATISTICS ================= -->
        <HBox spacing="30" alignment="CENTER">

            <VBox styleClass="loan-card loan-card-blue">
                <Label text="Total Loans"/>
                <Label fx:id="totalLoansLabel"/>
            </VBox>

            <VBox styleClass="loan-card loan-card-green">
                <Label text="Active Loans"/>
                <Label fx:id="activeLoansLabel"/>
            </VBox>

            <VBox styleClass="loan-card loan-card-red">
                <Label text="Pending Loans"/>
                <Label fx:id="pendingLoansLabel"/>
            </VBox>

            <VBox styleClass="loan-card loan-card-blue">
                <Label text="Completed Loans"/>
                <Label fx:id="completedLoansLabel"/>
            </VBox>

        </HBox>

        <!-- ================= CHARTS ================= -->
        <HBox spacing="40" alignment="CENTER">

            <VBox styleClass="header-container" spacing="15">
                <Label text="Loan Status Distribution"
                       styleClass="page-title"/>
                <PieChart fx:id="statusPieChart"
                          prefWidth="350"
                          prefHeight="300"/>
            </VBox>

            <VBox styleClass="header-container" spacing="15">
                <Label text="Risk Level Distribution"
                       styleClass="page-title"/>
                <BarChart fx:id="riskBarChart"
                          prefWidth="400"
                          prefHeight="300">
                    <xAxis>
                        <CategoryAxis label="Risk Level"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Number of Loans"/>
                    </yAxis>
                </BarChart>
            </VBox>

        </HBox>

        <!-- ================= AI INSIGHT ================= -->
        <VBox spacing="18"
              styleClass="ai-card">

            <HBox alignment="CENTER_LEFT">
                <Label text="AI Risk Insight"
                       styleClass="page-title"/>
            </HBox>

            <ScrollPane fx:id="aiScrollPane"
                        fitToWidth="true"
                        prefHeight="170"
                        styleClass="ai-scroll">

                <Label fx:id="aiMessageLabel"
                       wrapText="true"
                       styleClass="ai-message"/>
            </ScrollPane>

        </VBox>

        <!-- ================= NAVIGATION ================= -->
        <HBox spacing="30" alignment="CENTER">
            <Button text="Voir Demandes"
                    styleClass="btn-primary"
                    onAction="#goToLoanList"/>
        </HBox>

    </VBox>

</AnchorPane>