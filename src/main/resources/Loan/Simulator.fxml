<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane prefWidth="950" prefHeight="680"
            stylesheets="@/Styles/LoanStyle.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controlleurs.LoanControlleur.SimulatorController">

    <VBox alignment="TOP_CENTER"
          spacing="35"
          AnchorPane.topAnchor="30"
          AnchorPane.leftAnchor="60"
          AnchorPane.rightAnchor="60">

        <!-- ================= TITLE ================= -->
        <Label text="Simulation du prêt"
               styleClass="page-title"/>

        <!-- ================= TYPE SELECTION ================= -->
        <HBox spacing="25" alignment="CENTER">

            <Button text="🏠 Immobilier"
                    styleClass="loan-card-red"
                    onAction="#selectHousing"/>

            <Button text="🚗 Auto"
                    styleClass="loan-card-blue"
                    onAction="#selectCar"/>

            <Button text="🛒 Personnel"
                    styleClass="loan-card-green"
                    onAction="#selectPersonal"/>

        </HBox>

        <!-- ================= LOAN INFO ================= -->
        <HBox spacing="60"
              alignment="CENTER"
              styleClass="header-container">

            <VBox alignment="CENTER">
                <Label text="Montant maximal"/>
                <Label fx:id="maxAmountLabel"
                       styleClass="info-green"/>
            </VBox>

            <VBox alignment="CENTER">
                <Label text="Taux d'intérêt"/>
                <Label fx:id="rateLabel"
                       styleClass="info-blue"/>
            </VBox>

            <VBox alignment="CENTER">
                <Label text="Durée maximale"/>
                <Label fx:id="maxDurationLabel"
                       styleClass="info-red"/>
            </VBox>

        </HBox>

        <!-- ================= FORM ================= -->
        <VBox spacing="25"
              styleClass="form-container"
              alignment="CENTER">

            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="Montant du prêt :"/>
                <TextField fx:id="amountField"
                           promptText="Entrez le montant"/>
            </HBox>

            <VBox spacing="10">
                <Label text="Durée (mois)"/>
                <Slider fx:id="durationSlider"
                        min="12"
                        max="240"
                        blockIncrement="12"
                        showTickLabels="true"
                        showTickMarks="true"/>
                <Label fx:id="durationValueLabel"/>
            </VBox>

            <HBox spacing="30">
                <VBox spacing="8">
                    <Label text="Âge :"/>
                    <TextField fx:id="ageField"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Revenu mensuel :"/>
                    <TextField fx:id="incomeField"/>
                </VBox>
            </HBox>

            <Button text="Lancer la simulation"
                    styleClass="btn-primary"
                    onAction="#handleSimulation"/>

        </VBox>

        <!-- ================= RESULT CARD ================= -->
        <VBox fx:id="resultCard"
              spacing="15"
              alignment="CENTER"
              visible="false"
              styleClass="form-container">

            <Label text="Résultat de la simulation"
                   styleClass="result-title"/>

            <Label fx:id="monthlyResultLabel"
                   styleClass="result-main"/>

            <Label fx:id="totalResultLabel"
                   styleClass="result-secondary"/>

        </VBox>

    </VBox>

</AnchorPane>
