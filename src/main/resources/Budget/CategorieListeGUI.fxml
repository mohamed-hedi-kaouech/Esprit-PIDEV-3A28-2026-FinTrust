<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controlleurs.BudgetControlleur.CategorieListeController"
             prefWidth="900" prefHeight="600"
            stylesheets="/Styles/StyleBudgetWhite.css"
            styleClass="main-container">

    <!-- TOP BAR -->
    <top>
        <VBox styleClass="top-bar">
            <!-- Header with Back Button -->
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-bar">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>

                <Button text="⬅ Retour" onAction="#goBackToMenu" styleClass="btn-back">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Label text="💰 Liste des Catégories Budget" styleClass="page-title">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS"/>
                <!-- Notification dropdown -->
                <MenuButton fx:id="notificationMenu" text="🔔 Alertes" styleClass="btn-notification">
                    <!-- Menu items populated at runtime -->
                </MenuButton>
                

                <!-- Stats Summary -->
                <VBox alignment="CENTER" spacing="3" styleClass="stat-box">
                    <Label fx:id="lblTotalCategories" text="0" styleClass="stat-number">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <Label text="Catégories" styleClass="stat-label">
                        <font>
                            <Font size="10.0" />
                        </font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" spacing="3" styleClass="stat-box">
                    <Label fx:id="lblBudgetTotal" text="0.00 DT" styleClass="stat-number">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <Label text="Budget Total" styleClass="stat-label">
                        <font>
                            <Font size="10.0" />
                        </font>
                    </Label>
                </VBox>
            </HBox>

            <!-- Action Buttons -->
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="action-bar">
                <padding>
                    <Insets top="15" right="30" bottom="15" left="30"/>
                </padding>

                <Button text="➕ Ajouter Catégorie" onAction="#goToCreate" styleClass="btn-add" style="-fx-font-size: 13px; -fx-padding: 10px 20px;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <!-- Monthly PDF report button -->
                <Button text="📄 Rapport mensuel" onAction="#sendMonthlyReport" styleClass="btn-report" style="-fx-font-size: 13px; -fx-padding: 10px 20px;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search Bar -->
                <TextField fx:id="tfSearch" promptText="🔍 Rechercher une catégorie..."
                           prefWidth="280.0" styleClass="search-field" style="-fx-font-size: 13px;">
                    <font>
                        <Font size="13.0" />
                    </font>
                </TextField>

                <Button text="🔄 Réinitialiser" onAction="#resetSearch" styleClass="btn-reset" style="-fx-font-size: 12px; -fx-padding: 8px 15px;">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Button>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="20" styleClass="content-area">
            <padding>
                <Insets top="20" right="30" bottom="30" left="30"/>
            </padding>

            <!-- List Header -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="list-header">
                <Label text="📊" style="-fx-font-size:24px;"/>
                <Label text="Catégories" styleClass="list-title">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblFilteredCount" text="Affichage: 0 catégories" styleClass="filter-count">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
            </HBox>

            <!-- ListView -->
            <ListView fx:id="categorieListView" styleClass="categorie-listview" VBox.vgrow="ALWAYS"/>

            <!-- Footer with Totals -->
            <HBox alignment="CENTER" spacing="20" styleClass="list-footer">
                <padding>
                    <Insets top="15" bottom="15"/>
                </padding>

                <Label text="Total Budgets:" styleClass="footer-label">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <Label fx:id="lblSommeBudgets" text="0.00 DT" styleClass="footer-value">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>

                <Separator orientation="VERTICAL" prefHeight="20"/>

                <Label text="Total Seuils:" styleClass="footer-label">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <Label fx:id="lblSommeSeuils" text="0.00 DT" styleClass="footer-value-warning">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
            </HBox>

        </VBox>
    </center>

</BorderPane>