<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controlleurs.BudgetControlleur.ItemCreateController"
            prefWidth="1100" prefHeight="800"
            stylesheets="/Styles/StyleBudgetWhite.css"
            styleClass="main-container">
    <fx:define>
        <ToggleGroup fx:id="modeGroup" />
    </fx:define>

    <!-- TOP BAR -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-bar" AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

        <Button text="⬅ Retour" onAction="#goBackToListe" styleClass="btn-back">
            <font><Font name="System Bold" size="13.0"/></font>
        </Button>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="➕ Créer un Nouvel Item" styleClass="page-title">
            <font><Font name="System Bold" size="24.0"/></font>
        </Label>

        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- SCROLLPANE CONTENT -->
    <ScrollPane fitToWidth="true" fitToHeight="true"
                AnchorPane.topAnchor="80.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                style="-fx-background-color: transparent;">
        <VBox alignment="CENTER">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <VBox spacing="25" styleClass="form-card" maxWidth="500">
                <padding><Insets top="35" right="35" bottom="35" left="35"/></padding>

                <!-- Form Title -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="📝" style="-fx-font-size:32px;"/>
                    <VBox>
                        <Label text="Nouvel Item" styleClass="form-title"/>
                        <Label text="Remplissez les informations ci-dessous" styleClass="form-subtitle"/>
                    </VBox>
                </HBox>

                <!-- Mode selection -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="input-group">
                    <Label text="Mode d'ajout:" styleClass="input-label"/>
                    <RadioButton fx:id="rbManual" text="Manuel" toggleGroup="$modeGroup" selected="true"/>
                    <RadioButton fx:id="rbInvoice" text="Facture (OCR)" toggleGroup="$modeGroup"/>
                </HBox>

                <Separator styleClass="form-separator"/>

                <!-- Nom Item -->
                <VBox spacing="8" styleClass="input-group">
                    <Label text="Nom de l'Item *" styleClass="input-label"/>
                    <TextField fx:id="tfLibelle" promptText="Ex: Pain, Eau, Essence..." styleClass="input-field"/>
                </VBox>

                <!-- Prix -->
                <VBox spacing="8" styleClass="input-group">
                    <Label text="Prix  (DT) *" styleClass="input-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="tfMontant" promptText="0.00" styleClass="input-field"/>
                        <Label text="DT" styleClass="currency-label"/>
                    </HBox>
                </VBox>

                <!-- Date (optional) -->
                <VBox spacing="8" styleClass="input-group">
                    <Label text="Date (optionnel)" styleClass="input-label"/>
                    <DatePicker fx:id="dpDate" styleClass="input-field"/>
                </VBox>

                <!-- Fichier pour OCR (image/pdf/txt) -->
                <VBox fx:id="ocrContainer" spacing="8" styleClass="input-group">
                    <Label text="Fichier (OCR)" styleClass="input-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="tfFilePath" editable="false" styleClass="input-field"/>
                        <Button text="Parcourir" onAction="#chooseFile" styleClass="btn-browse"/>
                    </HBox>
                    <TextArea fx:id="taOcrResult" editable="false" prefRowCount="4" promptText="Résultat OCR..."/>
                </VBox>

                <Separator styleClass="form-separator"/>

                <!-- Form Buttons -->
                <Separator styleClass="form-separator"/>
                <HBox spacing="15" alignment="CENTER">
                    <Button text="💾 Enregistrer" onAction="#enregistrer" styleClass="btn-save" prefWidth="200" style="-fx-font-size: 13px;"/>
                    <Button text="🔄 Réinitialiser" onAction="#reinitialiser" styleClass="btn-reset" prefWidth="180" style="-fx-font-size: 13px;"/>
                </HBox>

            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>