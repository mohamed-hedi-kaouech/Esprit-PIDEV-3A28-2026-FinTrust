<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            fx:controller="org.example.Controlleurs.AdminControlleur.AdminAnalyticsDashboardController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT" spacing="12">
            <children>
                <Label text="Data Analytics Dashboard" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Rafraichir" styleClass="button-secondary" onAction="#handleRefresh"/>
                <Button text="Retour Admin" styleClass="button-secondary" onAction="#handleBack"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="12" style="-fx-padding: 18 24;" styleClass="bank-card">
            <HBox spacing="10">
                <VBox styleClass="admin-stat-card admin-stat-card-1" HBox.hgrow="ALWAYS">
                    <Label text="Actifs" styleClass="admin-stat-title"/>
                    <Label fx:id="activeUsersLabel" text="0" styleClass="admin-stat-value"/>
                </VBox>
                <VBox styleClass="admin-stat-card admin-stat-card-2" HBox.hgrow="ALWAYS">
                    <Label text="Dormants" styleClass="admin-stat-title"/>
                    <Label fx:id="dormantUsersLabel" text="0" styleClass="admin-stat-value"/>
                </VBox>
                <VBox styleClass="admin-stat-card admin-stat-card-3" HBox.hgrow="ALWAYS">
                    <Label text="A risque" styleClass="admin-stat-title"/>
                    <Label fx:id="atRiskUsersLabel" text="0" styleClass="admin-stat-value"/>
                </VBox>
                <VBox styleClass="admin-stat-card admin-stat-card-1" HBox.hgrow="ALWAYS">
                    <Label text="Tres actifs" styleClass="admin-stat-title"/>
                    <Label fx:id="veryActiveUsersLabel" text="0" styleClass="admin-stat-value"/>
                </VBox>
            </HBox>

            <HBox spacing="12">
                <VBox styleClass="admin-pie-card" prefWidth="360">
                    <Label text="Segmentation utilisateurs" styleClass="admin-pie-title"/>
                    <PieChart fx:id="segmentPieChart" prefHeight="250" styleClass="admin-status-pie"/>
                </VBox>

                <VBox styleClass="admin-pie-card" HBox.hgrow="ALWAYS">
                    <Label text="Heatmap logins par heure (30j)" styleClass="admin-pie-title"/>
                    <BarChart fx:id="loginHourBarChart" prefHeight="250">
                        <xAxis>
                            <CategoryAxis label="Heure"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Logins"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </HBox>

            <HBox spacing="10">
                <VBox styleClass="admin-stat-card admin-stat-card-2" HBox.hgrow="ALWAYS">
                    <Label text="Risque churn (>=45j)" styleClass="admin-stat-title"/>
                    <Label fx:id="churnCountLabel" text="0" styleClass="admin-stat-value"/>
                </VBox>
                <VBox styleClass="admin-stat-card admin-stat-card-1" HBox.hgrow="ALWAYS">
                    <Label text="OTP request success" styleClass="admin-stat-title"/>
                    <Label fx:id="otpRequestRateLabel" text="0%" styleClass="admin-stat-value"/>
                </VBox>
                <VBox styleClass="admin-stat-card admin-stat-card-1" HBox.hgrow="ALWAYS">
                    <Label text="OTP validation success" styleClass="admin-stat-title"/>
                    <Label fx:id="otpValidationRateLabel" text="0%" styleClass="admin-stat-value"/>
                </VBox>
                <VBox styleClass="admin-stat-card admin-stat-card-1" HBox.hgrow="ALWAYS">
                    <Label text="Temps moyen OTP" styleClass="admin-stat-title"/>
                    <Label fx:id="avgOtpTimeLabel" text="0s" styleClass="admin-stat-value"/>
                </VBox>
            </HBox>

            <HBox spacing="12" VBox.vgrow="ALWAYS">
                <VBox styleClass="admin-pie-card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Label text="Top 10 echecs login" styleClass="admin-pie-title"/>
                    <TableView fx:id="failedLoginTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="failedUserIdCol" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="failedEmailCol" text="Email" prefWidth="220"/>
                            <TableColumn fx:id="failedCountCol" text="Echecs 30j" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="admin-pie-card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Label text="Liste risque churn" styleClass="admin-pie-title"/>
                    <TableView fx:id="churnRiskTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="churnUserIdCol" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="churnEmailCol" text="Email" prefWidth="220"/>
                            <TableColumn fx:id="churnDaysCol" text="Jours inactifs" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>

            <Label fx:id="infoLabel" text="" styleClass="section-subtitle"/>
        </VBox>
    </center>
</BorderPane>
