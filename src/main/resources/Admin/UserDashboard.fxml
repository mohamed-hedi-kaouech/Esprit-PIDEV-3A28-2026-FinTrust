<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            fx:controller="org.example.Controlleurs.AdminControlleur.AdminUserDashboardController">

    <top>
        <VBox>
            <HBox styleClass="header-panel" alignment="CENTER_LEFT" spacing="12">
                <children>
                    <Label text="Administration Utilisateurs" styleClass="logo-text"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Analytics" onAction="#goToAnalyticsDashboard" styleClass="button-secondary"/>
                    <Button text="Mes taches" onAction="#goToAdminTasks" styleClass="button-secondary"/>
                    <Button text="Validation KYC" onAction="#goToKycValidation" styleClass="button-secondary"/>
                    <Button text="Formulaire" onAction="#goToCreateUserForm" styleClass="button-secondary"/>
                    <Button text="Menu" onAction="#goToMenu" styleClass="button-secondary"/>
                    <Button text="Deconnexion" onAction="#handleLogout" styleClass="button-secondary"/>
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="false" pannable="true"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="admin-dashboard-scroll">
            <content>
        <VBox spacing="14" fillWidth="true" style="-fx-padding: 22 26;" styleClass="bank-card">
            <HBox styleClass="section-header">
                <Label text="Liste des utilisateurs" styleClass="section-title"/>
            </HBox>
            <Label text="Validation et suivi des statuts" styleClass="section-subtitle"/>

            <HBox spacing="16" alignment="TOP_LEFT">
                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <HBox spacing="12">
                        <VBox styleClass="admin-stat-card admin-stat-card-1" HBox.hgrow="ALWAYS">
                            <Label text="Total utilisateurs" styleClass="admin-stat-title"/>
                            <Label fx:id="totalUsersLabel" text="0" styleClass="admin-stat-value"/>
                        </VBox>
                        <VBox styleClass="admin-stat-card admin-stat-card-2" HBox.hgrow="ALWAYS">
                            <Label text="Clients" styleClass="admin-stat-title"/>
                            <Label fx:id="totalClientsLabel" text="0" styleClass="admin-stat-value"/>
                        </VBox>
                        <VBox styleClass="admin-stat-card admin-stat-card-3" HBox.hgrow="ALWAYS">
                            <Label text="Admins" styleClass="admin-stat-title"/>
                            <Label fx:id="totalAdminsLabel" text="0" styleClass="admin-stat-value"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="admin-pie-card">
                    <Label text="Statut des comptes" styleClass="admin-pie-title"/>
                    <PieChart fx:id="statusPieChart" prefWidth="290" prefHeight="220" legendVisible="true" labelsVisible="true" styleClass="admin-status-pie"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="status-banner">
                <Label text="Recherche:" styleClass="form-label"/>
                <TextField fx:id="searchField" promptText="Nom, email, role, statut, id..." prefWidth="320"/>

                <Label text="Trier par:" styleClass="form-label"/>
                <ComboBox fx:id="sortByCombo" prefWidth="170"/>

                <Label text="Ordre:" styleClass="form-label"/>
                <ComboBox fx:id="sortOrderCombo" prefWidth="120"/>

                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Reset filtre" onAction="#handleResetFilter" styleClass="button-secondary"/>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" styleClass="admin-users-table-wrap">
                <TableView fx:id="usersTable" styleClass="admin-users-table"
                           minHeight="260.0" prefHeight="360.0" maxHeight="1.7976931348623157E308"
                           VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="nomColumn" text="Nom" prefWidth="180"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="280"/>
                    <TableColumn fx:id="roleColumn" text="Role" prefWidth="120"/>
                    <TableColumn fx:id="statusColumn" text="Statut" prefWidth="140"/>
                    <TableColumn fx:id="createdAtColumn" text="Cree le" prefWidth="180"/>
                </columns>
                </TableView>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="status-banner">
                <Label text="Nouveau statut:" styleClass="form-label"/>
                <ComboBox fx:id="statusComboBox" prefWidth="180"/>
                <Button text="Appliquer" onAction="#handleApplyStatus" styleClass="button-primary"/>
                <Button text="Rafraichir" onAction="#handleRefresh" styleClass="button-secondary"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Modifier" onAction="#handleEditUser" styleClass="button-secondary"/>
                <Button text="Supprimer" onAction="#handleDeleteUser" styleClass="button-danger"/>
            </HBox>

            <VBox spacing="8" styleClass="export-block">
                <Label text="Exports admin (Excel/PDF)" styleClass="export-title"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Utilisateurs" styleClass="export-label"/>
                    <Button text="Excel" onAction="#handleExportUsersExcel" styleClass="button-secondary export-btn"/>
                    <Button text="PDF" onAction="#handleExportUsersPdf" styleClass="button-secondary export-btn"/>

                    <Label text="Statistiques" styleClass="export-label"/>
                    <Button text="Excel" onAction="#handleExportAnalyticsExcel" styleClass="button-secondary export-btn"/>
                    <Button text="PDF" onAction="#handleExportAnalyticsPdf" styleClass="button-secondary export-btn"/>

                    <Label text="Audit logs" styleClass="export-label"/>
                    <Button text="Excel" onAction="#handleExportAuditExcel" styleClass="button-secondary export-btn"/>
                    <Button text="PDF" onAction="#handleExportAuditPdf" styleClass="button-secondary export-btn"/>
                </HBox>
            </VBox>

            <Label fx:id="infoLabel" text="" styleClass="section-subtitle"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Envoyer notification" onAction="#handleSendNotification" styleClass="button-secondary"/>
                <Button text="Retour" onAction="#handleBack" styleClass="button-secondary"/>
            </HBox>
        </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
