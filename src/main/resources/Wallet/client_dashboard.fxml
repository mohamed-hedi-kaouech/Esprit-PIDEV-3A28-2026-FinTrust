<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            prefWidth="1100" prefHeight="800"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.WalletControlleur.ClientDashboardController"
            fitToWidth="true"
            style="-fx-background: linear-gradient(to bottom, #f0f7ff, #e6f0ff); -fx-border-color: transparent;">

    <VBox spacing="25" alignment="TOP_CENTER"
          style="-fx-background-color: transparent; -fx-padding: 30;">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- En-tête avec bienvenue et bouton retour -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <!-- ✅ BOUTON RETOUR VERS LOGIN -->
                <Button text="← Déconnexion" onAction="#handleLogout"
                        style="-fx-background-color: #1f4ea0; -fx-text-fill: white; -fx-border-radius: 20; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblWelcome" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #003366; -fx-font-family: 'System';"/>
            </HBox>
            <Separator style="-fx-background-color: #e0e7ff; -fx-max-width: 100;"/>
        </VBox>

        <!-- Infos compte -->
        <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <Label text="Mon Compte" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #003366; -fx-font-family: 'System';"/>

            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="70"/>
                </columnConstraints>

                <Label text="Compte :" style="-fx-font-weight: bold; -fx-text-fill: #2f75d8; -fx-font-size: 14px;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblWalletName" style="-fx-text-fill: #1a2d44; -fx-font-size: 14px; -fx-font-weight: 600;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Solde actuel :" style="-fx-font-weight: bold; -fx-text-fill: #2e8b57; -fx-font-size: 14px;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <Label fx:id="lblSolde" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a2d44;"/>
                    <Label fx:id="lblDevise" style="-fx-text-fill: #6B7280; -fx-font-size: 14px;"/>
                </HBox>

                <Label text="Plafond découvert :" style="-fx-font-weight: bold; -fx-text-fill: #ff8c00; -fx-font-size: 14px;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <Label fx:id="lblPlafond" text="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2d44;"/>
                    <Label fx:id="lblDevisePlafond" text="TND" style="-fx-text-fill: #6B7280;"/>
                    <Label text="ⓘ" style="-fx-text-fill: #2f75d8; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 0 0 0 5;">
                        <tooltip>
                            <Tooltip text="Montant maximum autorisé en négatif" style="-fx-font-size: 12px;"/>
                        </tooltip>
                    </Label>
                </HBox>

                <Label text="Disponible :" style="-fx-font-weight: bold; -fx-text-fill: #1f4ea0; -fx-font-size: 14px;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="1">
                    <Label fx:id="lblDisponible" text="0.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    <Label fx:id="lblDeviseDispo" text="TND" style="-fx-text-fill: #6B7280;"/>
                </HBox>

                <Label text="Statut :" style="-fx-font-weight: bold; -fx-text-fill: #c0392b; -fx-font-size: 14px;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="lblStatutDecouvert" text="✅ Compte en positif"
                       style="-fx-font-weight: bold; -fx-text-fill: #27ae60; -fx-font-size: 14px;" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <!-- SECTION SCORE DE CONFIANCE -->
        <VBox spacing="15" style="-fx-background-color: linear-gradient(to right, #2f75d8, #4a9df7); -fx-padding: 25; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 4);">
            <Label text="🏆 Score de confiance FinTrust"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'System';"/>

            <HBox alignment="CENTER" spacing="20">
                <ProgressIndicator fx:id="progressScore" prefWidth="100" prefHeight="100"
                                   style="-fx-progress-color: white;"/>
                <VBox alignment="CENTER" spacing="5">
                    <Label fx:id="lblScore" text="0/100"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'System';"/>
                    <Label fx:id="lblNiveau" text="-"
                           style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-family: 'System';"/>
                </VBox>
            </HBox>

            <GridPane hgap="20" vgap="10" style="-fx-padding: 10 0; -fx-alignment: center;">
                <Label text="Ancienneté:" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblAnciennete" text="0/15" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Transactions:" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblTransactionsScore" text="0/20" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Stabilité:" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblStabilite" text="0/25" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Label fx:id="lblRecommandation"
                   style="-fx-background-color: rgba(255,255,255,0.15); -fx-padding: 15; -fx-background-radius: 12; -fx-text-fill: white; -fx-wrap-text: true; -fx-font-size: 14px; -fx-font-family: 'System';"/>
        </VBox>

        <!-- TABLEVIEW DES TRANSACTIONS -->
        <VBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <Label text="📋 Historique détaillé des transactions"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #003366; -fx-font-family: 'System';"/>

            <TableView fx:id="tableViewTransactions" VBox.vgrow="ALWAYS" prefHeight="400"
                       style="-fx-background-color: transparent; -fx-background-radius: 12;">
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="140" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colMontant" text="Montant" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
                    <TableColumn fx:id="colDevise" text="Devise" prefWidth="80" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colBeneficiaire" text="Bénéficiaire/Expéditeur" prefWidth="200" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="250" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" style="-fx-alignment: CENTER;"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Boutons d'action -->
        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 20 0;">
            <Button text="➕ Nouvelle Transaction"
                    onAction="#handleNewTransaction"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 30; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(39,174,96,0.3), 5, 0, 0, 2);"/>

            <Button text="💱 Convertisseur"
                    onAction="#handleOuvrirConvertisseur"
                    style="-fx-background-color: #1f4ea0; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 30; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(31,78,160,0.3), 5, 0, 0, 2);"/>

            <Button text="📒 Mon Chéquier"
                    onAction="#handleOuvrirChequier"
                    style="-fx-background-color: #ff8c00; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 30; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,140,0,0.3), 5, 0, 0, 2);"/>
        </HBox>
    </VBox>
</ScrollPane>