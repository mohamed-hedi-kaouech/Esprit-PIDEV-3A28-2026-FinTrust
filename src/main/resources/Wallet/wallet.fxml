<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.WalletControlleur.WalletController"
            prefHeight="750" prefWidth="900"
            style="-fx-background-color: #f4f7fc;">

    <top>
        <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <Label text="Gestion des Wallets"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>
            <Label text="Créez, modifiez et gérez les comptes clients"
                   style="-fx-font-size: 14px; -fx-text-fill: #6B7280;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent;">
            <VBox spacing="25" style="-fx-padding: 25;">

                <!-- Formulaire de saisie -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10;">
                    <Label text="Informations du Wallet"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>

                    <GridPane hgap="15" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="20"/>
                            <ColumnConstraints percentWidth="30"/>
                            <ColumnConstraints percentWidth="20"/>
                            <ColumnConstraints percentWidth="30"/>
                        </columnConstraints>

                        <!-- Ligne 1 : Propriétaire et Téléphone -->
                        <Label text="Propriétaire :" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtNomProprietaire" promptText="Nom du propriétaire"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Téléphone :" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtTelephone" promptText="+216XXXXXXXX"
                                   GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <!-- Ligne 2 : Email et Solde initial -->
                        <Label text="Email :" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtEmail" promptText="client@email.com"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Solde initial :" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtSolde" promptText="0.00"
                                   GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <!-- Ligne 3 : Devise et Statut -->
                        <Label text="Devise :" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="comboDevise" promptText="Sélectionner une devise"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Statut :" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="comboStatut" promptText="Sélectionner un statut"
                                  GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                        <!-- Ligne 4 : Plafond découvert avec explication -->
                        <Label text="Plafond découvert :" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtPlafondDecouvert" promptText="0.00"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <!-- Label d'explication pour le plafond -->
                        <Label text="(Montant maximum autorisé en négatif)"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 11px; -fx-font-style: italic;"
                               GridPane.rowIndex="3" GridPane.columnIndex="2" GridPane.columnSpan="2"/>
                    </GridPane>

                    <!-- Labels d'erreur -->
                    <GridPane hgap="15" vgap="5">
                        <Label fx:id="lblErrorNom" textFill="red" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        <Label fx:id="lblErrorTelephone" textFill="red" GridPane.rowIndex="4" GridPane.columnIndex="3"/>
                        <Label fx:id="lblErrorEmail" textFill="red" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                        <Label fx:id="lblErrorSolde" textFill="red" GridPane.rowIndex="5" GridPane.columnIndex="3"/>
                        <Label fx:id="lblErrorPlafond" textFill="red" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                    </GridPane>

                    <!-- Message d'information pour le code -->
                    <HBox style="-fx-background-color: #e8f5e9; -fx-padding: 10; -fx-background-radius: 5;" visible="false" fx:id="codeInfoBox">
                        <Label fx:id="lblCodeInfo" text="Code envoyé avec succès"
                               style="-fx-text-fill: #2e7d32;"/>
                    </HBox>

                    <!-- Boutons d'action -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button text="Ajouter" onAction="#handleAjouter"
                                style="-fx-background-color: #0A0A0A; -fx-text-fill: white; -fx-padding: 10 30; -fx-background-radius: 5;"/>
                        <Button text="Modifier" onAction="#handleModifier"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-padding: 10 30; -fx-background-radius: 5;"/>
                        <Button text="Supprimer" onAction="#handleSupprimer"
                                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-padding: 10 30; -fx-background-radius: 5;"/>
                        <Button text="Vider" onAction="#handleVider"
                                style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-padding: 10 30; -fx-background-radius: 5;"/>
                    </HBox>
                </VBox>

                <!-- Liste des wallets -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10;">
                    <Label text="Liste des Wallets"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>

                    <TableView fx:id="tableViewWallet" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colNom" text="Propriétaire" prefWidth="150"/>
                            <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                            <TableColumn fx:id="colSolde" text="Solde" prefWidth="100"/>
                            <TableColumn fx:id="colPlafond" text="Plafond déc." prefWidth="100"/>
                            <TableColumn fx:id="colDevise" text="Devise" prefWidth="80"/>
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="80"/>
                            <TableColumn fx:id="colDate" text="Date création" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>