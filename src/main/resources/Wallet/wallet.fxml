<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@../Styles/StyleWallet.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controlleurs.WalletControlleur.WalletController">

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="25" style="-fx-background-color: #f8fafc;" alignment="TOP_CENTER">
                <padding>
                    <Insets bottom="30" left="30" right="30" top="30" />
                </padding>

                <children>
                    <!-- Formulaire Wallet -->
                    <VBox spacing="20" styleClass="form-container">
                        <children>
                            <Label text="➕ Nouveau Wallet" styleClass="form-title" />
                            <Label text="Créez un nouveau compte bancaire" styleClass="form-subtitle" />

                            <GridPane styleClass="form-grid">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="150" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="250" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="200" />
                                </columnConstraints>

                                <!-- Nom propriétaire -->
                                <Label text="Propriétaire" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <TextField fx:id="txtNomProprietaire" promptText="Ex: Jean Dupont" styleClass="form-field" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                <Label fx:id="lblErrorNom" styleClass="error-label" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                <!-- Solde initial -->
                                <Label text="Solde initial" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <TextField fx:id="txtSolde" promptText="0.00" styleClass="form-field" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                                <Label fx:id="lblErrorSolde" styleClass="error-label" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                                <!-- Devise -->
                                <Label text="Devise" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                <ComboBox fx:id="comboDevise" prefWidth="250" promptText="Sélectionner une devise" styleClass="form-combo" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                                <Label fx:id="lblErrorDevise" styleClass="error-label" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                                <!-- Statut -->
                                <Label text="Statut" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                                <ComboBox fx:id="comboStatut" prefWidth="250" promptText="Sélectionner un statut" styleClass="form-combo" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                                <Label fx:id="lblErrorStatut" styleClass="error-label" GridPane.rowIndex="7" GridPane.columnIndex="1" />
                            </GridPane>

                            <!-- Boutons d'action -->
                            <HBox styleClass="button-container">
                                <children>
                                    <Button text="Ajouter" onAction="#handleAjouter" styleClass="primary-button">
                                        <graphic>
                                            <Label text="✓" styleClass="button-icon" />
                                        </graphic>
                                    </Button>
                                    <Button text="Modifier" onAction="#handleModifier" styleClass="secondary-button">
                                        <graphic>
                                            <Label text="✎" styleClass="button-icon" />
                                        </graphic>
                                    </Button>
                                    <Button text="Supprimer" onAction="#handleSupprimer" styleClass="danger-button">
                                        <graphic>
                                            <Label text="🗑" styleClass="button-icon" />
                                        </graphic>
                                    </Button>
                                    <Button text="Vider" onAction="#handleVider" styleClass="secondary-button">
                                        <graphic>
                                            <Label text="⟲" styleClass="button-icon" />
                                        </graphic>
                                    </Button>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- Liste des Wallets -->
                    <VBox spacing="20" styleClass="table-container">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="📋 Liste des Wallets" styleClass="table-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="Total: " styleClass="table-stats" />
                            </HBox>

                            <TableView fx:id="tableViewWallet" VBox.vgrow="ALWAYS" styleClass="modern-table">
                                <columns>
                                    <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                                    <TableColumn fx:id="colNom" prefWidth="200" text="Propriétaire" />
                                    <TableColumn fx:id="colSolde" prefWidth="120" text="Solde" />
                                    <TableColumn fx:id="colDevise" prefWidth="100" text="Devise" />
                                    <TableColumn fx:id="colStatut" prefWidth="120" text="Statut" />
                                    <TableColumn fx:id="colDate" prefWidth="150" text="Date création" />
                                </columns>
                            </TableView>
                        </children>
                    </VBox>
                </children>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>