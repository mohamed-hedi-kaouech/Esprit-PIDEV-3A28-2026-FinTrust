<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.Controlleurs.WalletControlleur.ChequierClientController"
      spacing="20" prefWidth="1100" prefHeight="800"
      style="-fx-background-color: #f4f7fc; -fx-padding: 20;">

    <Label text="📒 Mon Chéquier"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e3c72;"/>

    <TitledPane text="Émettre un nouveau chèque" expanded="true">
        <GridPane hgap="15" vgap="15" style="-fx-padding: 15;">
            <Label text="Numéro du chèque :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtNumeroCheque" promptText="Ex: 123456" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Montant :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtMontant" promptText="0.00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Bénéficiaire :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtBeneficiaire" promptText="Nom du bénéficiaire" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Button text="Émettre le chèque" onAction="#handleEmettre"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5;"
                    GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>
    </TitledPane>

    <TitledPane text="Mes chèques" expanded="true">
        <TableView fx:id="tableViewCheques" prefHeight="300">
            <columns>
                <TableColumn fx:id="colNumero" text="N° Chèque" prefWidth="100"/>
                <TableColumn fx:id="colMontant" text="Montant" prefWidth="100"/>
                <TableColumn fx:id="colBeneficiaire" text="Bénéficiaire" prefWidth="150"/>
                <TableColumn fx:id="colDateEmission" text="Date émission" prefWidth="150"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                <!-- ✅ NOUVELLE COLONNE : Motif de rejet -->
                <TableColumn fx:id="colMotif" text="Motif rejet" prefWidth="150"/>
            </columns>
        </TableView>
    </TitledPane>
</VBox>