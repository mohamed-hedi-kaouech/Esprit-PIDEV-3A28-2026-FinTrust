<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.WalletControlleur.RiskDashboardController"
            style="-fx-background-color: #f5f7fa;">

    <top>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: linear-gradient(to right, #003366, #1e3b5c);">
            <Label text="🧠 Risk Intelligence Dashboard - FinTrust"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'System';"/>

            <!-- Statistiques en bleu uniquement -->
            <HBox spacing="20" alignment="CENTER">
                <!-- Fiables - bleu clair -->
                <VBox spacing="5" style="-fx-background-color: #e6f0ff; -fx-padding: 15; -fx-background-radius: 16; -fx-min-width: 150; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <Label text="🟢 Fiables" style="-fx-text-fill: #2f75d8; -fx-font-size: 16px; -fx-font-weight: 600;"/>
                    <Label fx:id="lblFiablesNombre" text="0" style="-fx-text-fill: #1a2d44; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblFiablesPourcent" text="0%" style="-fx-text-fill: #4a9df7; -fx-font-size: 14px;"/>
                    <Label fx:id="lblFiablesEvolution" text="+0%" style="-fx-text-fill: #2f75d8; -fx-font-size: 12px;"/>
                </VBox>

                <!-- Moyens - bleu moyen -->
                <VBox spacing="5" style="-fx-background-color: #d9e8ff; -fx-padding: 15; -fx-background-radius: 16; -fx-min-width: 150; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <Label text="🟡 Moyens" style="-fx-text-fill: #4a9df7; -fx-font-size: 16px; -fx-font-weight: 600;"/>
                    <Label fx:id="lblMoyensNombre" text="0" style="-fx-text-fill: #1a2d44; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblMoyensPourcent" text="0%" style="-fx-text-fill: #2f75d8; -fx-font-size: 14px;"/>
                    <Label fx:id="lblMoyensEvolution" text="0%" style="-fx-text-fill: #4a9df7; -fx-font-size: 12px;"/>
                </VBox>

                <!-- Risqués - bleu foncé -->
                <VBox spacing="5" style="-fx-background-color: #c9d9ff; -fx-padding: 15; -fx-background-radius: 16; -fx-min-width: 150; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <Label text="🔴 Risqués" style="-fx-text-fill: #1f4ea0; -fx-font-size: 16px; -fx-font-weight: 600;"/>
                    <Label fx:id="lblRisqueNombre" text="0" style="-fx-text-fill: #1a2d44; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblRisquePourcent" text="0%" style="-fx-text-fill: #2f75d8; -fx-font-size: 14px;"/>
                    <Label fx:id="lblRisqueEvolution" text="+0%" style="-fx-text-fill: #1f4ea0; -fx-font-size: 12px;"/>
                </VBox>

                <PieChart fx:id="pieChartRepartition" prefWidth="200" prefHeight="150"
                          style="-fx-pie-color-1: #2f75d8; -fx-pie-color-2: #4a9df7; -fx-pie-color-3: #7bb0ff;"/>
            </HBox>

            <!-- Filtres -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍 Filtres :" style="-fx-text-fill: #e7f3ff; -fx-font-family: 'System';"/>
                <ComboBox fx:id="comboNiveau" promptText="Niveau de risque"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e7ff; -fx-border-radius: 12; -fx-padding: 8 15; -fx-font-size: 14px;">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Tous"/>
                            <String fx:value="🔴 Risqué"/>
                            <String fx:value="🟡 Moyen"/>
                            <String fx:value="🟢 Fiable"/>
                        </FXCollections>
                    </items>
                </ComboBox>

                <TextField fx:id="txtScoreMin" promptText="Score min" prefWidth="80"
                           style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e7ff; -fx-border-radius: 12; -fx-padding: 8 12; -fx-font-size: 14px;"/>
                <TextField fx:id="txtScoreMax" promptText="Score max" prefWidth="80"
                           style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e7ff; -fx-border-radius: 12; -fx-padding: 8 12; -fx-font-size: 14px;"/>

                <CheckBox fx:id="chkSurveillance" text="Clients à surveiller"
                          style="-fx-text-fill: white; -fx-font-family: 'System';"/>

                <Button text="🔍 Appliquer" onAction="#appliquerFiltres"
                        style="-fx-background-color: #2f75d8; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 8 25; -fx-cursor: hand; -fx-font-family: 'System';"/>
                <Button text="🔄 Reset" onAction="#resetFiltres"
                        style="-fx-background-color: #1f4ea0; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 8 25; -fx-cursor: hand; -fx-font-family: 'System';"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <Label text="📋 Analyse des clients" style="-fx-text-fill: #003366; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'System';"/>

            <TableView fx:id="tableViewClients" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #e0e7ff; -fx-border-radius: 16;">
                <columns>
                    <TableColumn fx:id="colClient" text="Client" prefWidth="150" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="colScore" text="Score" prefWidth="70" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colPrivilege" text="Privilège" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colChequesRefuses" text="Chèques refusés" prefWidth="120" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colSolde" text="Solde" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
                    <TableColumn fx:id="colAction" text="Action" prefWidth="100" style="-fx-alignment: CENTER;"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #eef2f8;">
            <TitledPane text="🚨 CLIENTS À SURVEILLER" expanded="true"
                        style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e7ff; -fx-border-radius: 12;">
                <ListView fx:id="listSurveillance" prefHeight="100"
                          style="-fx-background-color: white; -fx-background-radius: 12;"/>
            </TitledPane>

            <HBox spacing="10" alignment="CENTER">
                <Button text="🧠 Générer analyse IA" onAction="#genererAnalyseIA"
                        style="-fx-background-color: #2f75d8; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 12 25; -fx-cursor: hand; -fx-font-size: 14px; -fx-font-family: 'System';"/>

                <TextArea fx:id="txtAnalyseIA" promptText="L'analyse IA apparaîtra ici..."
                          prefRowCount="4" HBox.hgrow="ALWAYS" editable="false"
                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e0e7ff; -fx-border-radius: 12; -fx-padding: 12; -fx-font-family: 'System'; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>