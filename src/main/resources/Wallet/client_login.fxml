<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controlleurs.WalletControlleur.ClientLoginController"
            prefHeight="500" prefWidth="800"
            style="-fx-background-color: linear-gradient(to bottom right, #f0f7ff, #e6f0ff);">

    <center>
        <HBox alignment="CENTER" spacing="0">
            <!-- Panneau gauche (image/info) -->
            <VBox alignment="CENTER" spacing="20"
                  style="-fx-background-color: linear-gradient(to bottom, #003366, #0047ab); -fx-padding: 50;"
                  prefWidth="350" prefHeight="500">

                <Label text="FinTrust"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Label text="Haute Finance Numérique"
                       style="-fx-font-size: 14px; -fx-text-fill: #b0c4de;"/>

                <VBox alignment="CENTER" spacing="15" style="-fx-padding: 30 0 0 0;">
                    <Label text="🔒" style="-fx-font-size: 40px;"/>
                    <Label text="Connexion sécurisée"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Authentification à deux facteurs"
                           style="-fx-font-size: 12px; -fx-text-fill: #b0c4de;"/>
                </VBox>
            </VBox>

            <!-- Panneau droit (formulaire) -->
            <VBox alignment="CENTER" spacing="25"
                  style="-fx-background-color: white; -fx-padding: 50; -fx-background-radius: 0 20 20 0;"
                  prefWidth="450" prefHeight="500">

                <Label text="Espace Client"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #003366;"/>

                <Label text="Accédez à vos comptes en toute sécurité"
                       style="-fx-font-size: 14px; -fx-text-fill: #6B7280;"/>

                <VBox spacing="15" maxWidth="300">
                    <Label text="Identifiant" style="-fx-font-weight: bold; -fx-text-fill: #003366;"/>
                    <TextField fx:id="txtIdentifiant" promptText="Téléphone ou Email"
                               style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>

                    <Label text="Code d'accès" style="-fx-font-weight: bold; -fx-text-fill: #003366; -fx-padding: 10 0 0 0;"/>
                    <PasswordField fx:id="txtCode" promptText="Code à 6 chiffres"
                                   style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>

                <Button text="Se connecter"
                        onAction="#handleLogin"
                        maxWidth="300"
                        style="-fx-background-color: #0047ab; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 30; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"
                        onMouseEntered="#handleButtonHover"
                        onMouseExited="#handleButtonExit"/>

                <HBox spacing="10" alignment="CENTER">
                    <Label text="Nouveau client ?" style="-fx-text-fill: #6B7280;"/>
                    <Label text="Souscrire"
                           style="-fx-text-fill: #0047ab; -fx-font-weight: bold; -fx-underline: true; -fx-cursor: hand;"
                           onMouseClicked="#handleSouscrire"/>
                </HBox>

                <!-- Navigation -->
                <HBox spacing="20" alignment="CENTER" style="-fx-padding: 30 0 0 0;">
                    <Label text="← Retour"
                           style="-fx-text-fill: #003366; -fx-cursor: hand;"
                           onMouseClicked="#handleRetour"/>
                    <Label text="|" style="-fx-text-fill: #ccc;"/>
                    <Label text="Aide"
                           style="-fx-text-fill: #003366; -fx-cursor: hand;"
                           onMouseClicked="#handleNavigation"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>