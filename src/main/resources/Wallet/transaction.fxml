<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@../Styles/StyleWallet.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controlleurs.WalletControlleur.TransactionController">

    <top>
        <VBox styleClass="header-panel" spacing="5">
            <padding><Insets bottom="20" left="30" right="30" top="20" /></padding>
            <Label text="Gestion des Transactions" styleClass="header-title" />
            <Label text="Effectuez vos opérations bancaires en toute sécurité" styleClass="header-subtitle" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="25" style="-fx-background-color: #f8fafc;" VBox.vgrow="ALWAYS">
                <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>

                <children>
                    <!-- Formulaire Transaction -->
                    <VBox spacing="20" styleClass="form-container">
                        <Label text="➕ Nouvelle Transaction" styleClass="form-title" />

                        <GridPane hgap="20" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="150" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="300" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="200" />
                            </columnConstraints>

                            <!-- Montant -->
                            <Label text="Montant" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <TextField fx:id="txtMontant" promptText="0.00" styleClass="form-field" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                            <Label fx:id="lblErrorMontant" styleClass="error-label" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                            <!-- Destinataire (visible uniquement pour transfert) -->
                            <Label text="Destinataire" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                            <TextField fx:id="txtDestinataire" promptText="Téléphone du destinataire"
                                       styleClass="form-field" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                       visible="false" managed="false" />
                            <Label fx:id="lblDestinataireInfo" styleClass="info-label"
                                   GridPane.rowIndex="2" GridPane.columnIndex="2"
                                   visible="false" managed="false" />

                            <!-- Type avec RadioButtons -->
                            <Label text="Type" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                            <HBox spacing="20" alignment="CENTER_LEFT" GridPane.rowIndex="4" GridPane.columnIndex="1">
                                <RadioButton fx:id="radioDepot" text="Dépôt" styleClass="transaction-radio" />
                                <RadioButton fx:id="radioRetrait" text="Retrait" styleClass="transaction-radio" />
                                <RadioButton fx:id="radioTransfert" text="Transfert" styleClass="transaction-radio" />
                            </HBox>
                            <Label fx:id="lblErrorType" styleClass="error-label" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                            <!-- Wallet -->
                            <Label text="Wallet" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                            <ComboBox fx:id="comboWallet" prefWidth="300" promptText="Sélectionner un compte" styleClass="form-combo" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                            <Label fx:id="lblErrorWallet" styleClass="error-label" GridPane.rowIndex="7" GridPane.columnIndex="1" />

                            <!-- Informations du wallet -->
                            <HBox spacing="15" alignment="CENTER_LEFT" GridPane.rowIndex="8" GridPane.columnIndex="1">
                                <VBox styleClass="info-card">
                                    <Label text="Compte sélectionné" styleClass="info-card-label" />
                                    <Label fx:id="lblWalletInfo" text="Aucun" styleClass="info-card-value" />
                                </VBox>
                                <VBox styleClass="info-card">
                                    <Label text="Solde disponible" styleClass="info-card-label" />
                                    <Label fx:id="lblSoldeActuel" text="0.00" styleClass="info-card-value" />
                                </VBox>
                            </HBox>
                        </GridPane>

                        <!-- Boutons -->
                        <HBox styleClass="button-container">
                            <Button text="Effectuer" onAction="#handleAjouter" styleClass="primary-button">
                                <graphic><Label text="✓" styleClass="button-icon" /></graphic>
                            </Button>
                            <Button text="Modifier" onAction="#handleModifier" styleClass="secondary-button">
                                <graphic><Label text="✎" styleClass="button-icon" /></graphic>
                            </Button>
                            <Button text="Supprimer" onAction="#handleSupprimer" styleClass="danger-button">
                                <graphic><Label text="🗑" styleClass="button-icon" /></graphic>
                            </Button>
                            <Button text="Vider" onAction="#handleVider" styleClass="secondary-button">
                                <graphic><Label text="⟲" styleClass="button-icon" /></graphic>
                            </Button>
                            <Button text="Rafraîchir" onAction="#handleRefresh" styleClass="secondary-button">
                                <graphic><Label text="↻" styleClass="button-icon" /></graphic>
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- Historique des Transactions -->
                    <VBox spacing="20" styleClass="table-container">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📊 Historique des Transactions" styleClass="table-title" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblTotalTransactions" text="Total: 0 transactions" styleClass="table-stats" />
                        </HBox>

                        <TableView fx:id="tableViewTransaction" VBox.vgrow="ALWAYS" styleClass="modern-table">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                                <TableColumn fx:id="colMontant" prefWidth="120" text="Montant" />
                                <TableColumn fx:id="colType" prefWidth="100" text="Type" />
                                <TableColumn fx:id="colDate" prefWidth="150" text="Date" />
                                <TableColumn fx:id="colWalletId" prefWidth="100" text="Wallet ID" />
                            </columns>
                        </TableView>
                    </VBox>
                </children>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>