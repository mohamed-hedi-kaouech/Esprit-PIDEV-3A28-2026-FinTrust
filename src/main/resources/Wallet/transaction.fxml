<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="10" stylesheets="@../Styles/StyleWallet.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.Controlleurs.WalletControlleur.TransactionController">
    <children>
        <Label styleClass="header-label" text="Gestion des Transactions">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>

        <TitledPane animated="false" expanded="true" text="Formulaire Transaction">
            <content>
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="150.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Montant :" />
                        <TextField fx:id="txtMontant" GridPane.columnIndex="1" />
                        <Label fx:id="lblErrorMontant" styleClass="error-label" textFill="RED" GridPane.columnIndex="2" />

                        <Label text="Type :" GridPane.rowIndex="1" />
                        <ComboBox fx:id="comboType" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label fx:id="lblErrorType" styleClass="error-label" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                        <Label text="Wallet :" GridPane.rowIndex="2" />
                        <ComboBox fx:id="comboWallet" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label fx:id="lblErrorWallet" styleClass="error-label" textFill="RED" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <children>
                                <Label styleClass="info-label" text="Wallet:" />
                                <Label fx:id="lblWalletInfo" styleClass="info-value" />
                                <Label styleClass="info-label" text="Solde:" />
                                <Label fx:id="lblSoldeActuel" styleClass="info-value" />
                            </children>
                        </HBox>
                    </children>
                    <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
                </GridPane>
            </content>
        </TitledPane>

        <HBox alignment="CENTER" spacing="10">
            <children>
                <Button mnemonicParsing="false" onAction="#handleAjouter" styleClass="action-button" text="Effectuer" />
                <Button mnemonicParsing="false" onAction="#handleModifier" styleClass="action-button" text="Modifier" />
                <Button mnemonicParsing="false" onAction="#handleSupprimer" styleClass="action-button" text="Supprimer" />
                <Button mnemonicParsing="false" onAction="#handleVider" styleClass="action-button" text="Vider" />
                <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="action-button" text="Rafraîchir" />
            </children>
            <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
        </HBox>

        <TitledPane animated="false" expanded="true" text="Historique des Transactions" VBox.vgrow="ALWAYS">
            <content>
                <TableView fx:id="tableViewTransaction" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="75" text="ID" />
                        <TableColumn fx:id="colMontant" prefWidth="100" text="Montant" />
                        <TableColumn fx:id="colType" prefWidth="100" text="Type" />
                        <TableColumn fx:id="colDate" prefWidth="150" text="Date" />
                        <TableColumn fx:id="colWalletId" prefWidth="100" text="Wallet ID" />
                    </columns>
                </TableView>
            </content>
        </TitledPane>
    </children>
    <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
</VBox>