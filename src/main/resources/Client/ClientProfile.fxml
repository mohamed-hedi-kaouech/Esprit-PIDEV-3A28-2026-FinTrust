<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            fx:controller="org.example.Controlleurs.ClientControlleur.ClientProfileController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT" spacing="12">
            <children>
                <Label text="Profil Client" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Retour Dashboard" onAction="#goToDashboard" styleClass="button-secondary"/>
                <Button text="Deconnexion" onAction="#handleLogout" styleClass="button-secondary"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 32;" styleClass="bank-card">
            <Label text="Vos informations" styleClass="section-title"/>
            <Label text="Nom" styleClass="form-label"/>
            <TextField fx:id="nomField" promptText="Nom"/>
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="emailField" promptText="Email"/>
            <Label text="Téléphone" styleClass="form-label"/>
            <TextField fx:id="numTelField" promptText="Téléphone"/>
            <HBox spacing="18" alignment="CENTER">
                <Button text="Modifier" onAction="#handleEdit" styleClass="new-transaction-button"/>
            </HBox>
            <Label fx:id="infoLabel" style="-fx-font-size: 13px; -fx-padding: 8 0 0 0;"/>
        </VBox>
    </center>
</BorderPane>
