<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            fx:controller="org.example.Controlleurs.ClientControlleur.NotificationsController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT" spacing="12">
            <children>
                <Label text="Notifications" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Retour" onAction="#goBack" styleClass="button-secondary"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="admin-dashboard-scroll">
            <content>
                <VBox spacing="12" style="-fx-padding: 26;" styleClass="bank-card">
                    <Label text="Historique" styleClass="section-title"/>
                    <ListView fx:id="notifList" VBox.vgrow="ALWAYS"/>
                    <HBox spacing="12">
                        <Button text="Marquer tout comme lu" onAction="#markAllRead" styleClass="button-secondary"/>
                    </HBox>
                    <Label fx:id="infoLabel" text="" styleClass="section-subtitle"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>