<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            fx:controller="org.example.Controlleurs.ClientControlleur.ClientDashboardController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT" spacing="12">
            <children>
                <Label text="Dashboard Client" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Deconnexion" onAction="#handleLogout" styleClass="button-secondary"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="admin-dashboard-scroll">
            <content>
        <VBox spacing="14" style="-fx-padding: 26;" styleClass="bank-card">

            <Label fx:id="welcomeLabel" text="Bienvenue" styleClass="section-title"/>
            <Label fx:id="kycStatusLabel" text="Statut KYC" styleClass="section-subtitle status-banner"/>
            <Label fx:id="kycCommentLabel" text="" styleClass="section-subtitle status-banner" wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="status-banner">
                <Label text="Notifications:" styleClass="form-label"/>
                <Label fx:id="notifCountLabel" text="0" style="-fx-font-weight: 800;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Voir historique" onAction="#goToNotifications" styleClass="button-secondary"/>
            </HBox>

            <VBox spacing="8" styleClass="client-reward-panel">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Recompenses FinTrust" styleClass="client-reward-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="rewardMedalLabel" text="Niveau Starter" styleClass="client-reward-medal"/>
                </HBox>
                <HBox spacing="14">
                    <VBox styleClass="client-reward-chip">
                        <Label text="Niveau" styleClass="client-reward-chip-title"/>
                        <Label fx:id="rewardLevelLabel" text="STARTER" styleClass="client-reward-chip-value"/>
                    </VBox>
                    <VBox styleClass="client-reward-chip">
                        <Label text="Points" styleClass="client-reward-chip-title"/>
                        <Label fx:id="rewardPointsLabel" text="0 pts" styleClass="client-reward-chip-value"/>
                    </VBox>
                </HBox>
                <Label text="Badges obtenus" styleClass="client-reward-subtitle"/>
                <Label fx:id="rewardBadgesLabel" text="Aucun badge pour le moment" wrapText="true" styleClass="client-reward-badges"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="status-banner">
                <Label text="AI" styleClass="assistant-ia-icon"/>
                <Label text="Assistant IA:" styleClass="form-label"/>
                <Label text="Besoin d'aide rapide sur votre compte ?" styleClass="section-subtitle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Ouvrir l'assistant IA" onAction="#goToChatbot" styleClass="button-primary assistant-ai-btn">
                    <graphic>
                        <Label text="AI" styleClass="assistant-ai-btn-icon"/>
                    </graphic>
                </Button>
            </HBox>

            <HBox spacing="12" fillHeight="true">
                <Button fx:id="profileButton" text="Profil" onAction="#goToProfile" styleClass="button-primary"/>
                <Button fx:id="MarketButton" text="Market" onAction="#goToMarket" styleClass="button-secondary"/>
                <Button fx:id="AbonnementsButton" text="Abonnements" onAction="#goToAbonnements" styleClass="button-secondary"/>
                <Button fx:id="walletButton" text="Wallet" onAction="#goToWalletDashboard" styleClass="button-secondary"/>
                <Button text="KYC" onAction="#goToKycForm" styleClass="button-secondary"/>
                <Button text="Pause et Jeux" onAction="#goToSmartBreakFromProfile" styleClass="button-secondary"/>
                <Button fx:id="loanButton" text="Loan" onAction="#goToLoan" styleClass="button-secondary"/>
                <Button fx:id="budgetButton" text="Budget" onAction="#goToBudget" styleClass="button-secondary"/>
                <Button fx:id="publicationButton" text="Publications" onAction="#goToPublications" styleClass="button-secondary"/>
            </HBox>

            <HBox spacing="18" alignment="CENTER_LEFT" styleClass="status-banner">
                <VBox spacing="8">
                    <Label text="Votre QR KYC (auto-genere)" styleClass="form-label"/>
                    <ImageView fx:id="qrImageView" fitWidth="220" fitHeight="220" preserveRatio="true"/>
                    <Label fx:id="qrInfoLabel" text="" styleClass="section-subtitle" wrapText="true"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="10" alignment="TOP_RIGHT">
                    <Label text="Ce QR contient vos informations client + KYC." styleClass="section-subtitle" wrapText="true"/>
                    <Button text="Regenerer QR" onAction="#handleRefreshQr" styleClass="button-secondary"/>
                </VBox>
            </HBox>

        </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>


