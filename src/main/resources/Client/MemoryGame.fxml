<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../Styles/StyleWallet.css"
            prefWidth="1100" prefHeight="800"
            fx:controller="org.example.Controlleurs.ClientControlleur.MemoryGameController">

    <top>
        <HBox styleClass="header-panel" alignment="CENTER_LEFT" spacing="10">
            <children>
                <Label text="Pause Intelligente - Memory Sprint 60s" styleClass="logo-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Retour" onAction="#handleBack" styleClass="button-secondary"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="admin-dashboard-scroll">
            <content>
                <VBox spacing="14" style="-fx-padding: 22;" styleClass="bank-card">
                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="status-banner">
                        <Label fx:id="contextLabel" text="Contexte: PROFILE" styleClass="form-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Temps:" styleClass="form-label"/>
                        <Label fx:id="timerLabel" text="60s" styleClass="client-reward-chip-value"/>
                        <Label text="Score:" styleClass="form-label"/>
                        <Label fx:id="scoreLabel" text="0" styleClass="client-reward-chip-value"/>
                    </HBox>

                    <GridPane fx:id="boardGrid" hgap="10" vgap="10"/>
                    <Label fx:id="infoLabel" text="" styleClass="section-subtitle"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>